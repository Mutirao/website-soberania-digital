---
/* eslint-disable @typescript-eslint/no-explicit-any */
export interface Props {
  conf: any;
  asset: (p: string) => string;
}
const { conf, asset } = Astro.props;
---

<section class="bg-[#010101]">
  <!-- mobile hero -->
  <div class="md:hidden">
    <img
      src={asset('/banner-encontro-1080.png')}
      alt="2º Encontro Nacional pela Soberania Digital — 18 e 19 de Maio, Brasília"
      class="w-full block"
      loading="eager"
    />
    <div class="px-5 py-8 text-center">
      <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-4">
        2º Encontro Nacional pela Soberania Digital
      </p>
      <div class="flex flex-wrap gap-3 justify-center mb-6">
        <div class="text-center">
          <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-0.5">Quando</p>
          <p class="text-white font-bold text-lg">18 e 19 de Maio</p>
        </div>
        <div class="text-center">
          <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-0.5">Onde</p>
          <p class="text-white font-bold text-lg">Brasília / DF</p>
        </div>
      </div>
      <a
        href={conf.callToAction.link}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center min-h-[52px] bg-[#E31B23] hover:bg-[#b01015] text-white font-black text-lg uppercase py-3 px-8 border-l-4 border-[#FFD400] transition-colors w-full"
      >
        Inscreva-se
      </a>
      <a
        href={asset('/encontro.ics')}
        download
        class="mt-3 inline-flex items-center justify-center gap-2 min-h-[44px] border border-[#333] text-[#E7E7D8] hover:border-[#FFD400] hover:text-[#FFD400] font-bold uppercase py-2 px-4 transition-colors text-xs w-full"
      >
        <span aria-hidden="true">↓</span> Adicionar à agenda (.ics)
      </a>
    </div>
  </div>

  <!-- desktop hero -->
  <div class="hidden md:flex items-center gap-10 max-w-6xl mx-auto px-6 py-12 lg:py-16">
    <div class="flex-1 min-w-0">
      <img
        src={asset('/banner-encontro-1080.png')}
        alt="2º Encontro Nacional pela Soberania Digital"
        class="w-full max-h-[60vh] object-contain block"
        loading="eager"
      />
    </div>
    <div class="flex-shrink-0 w-72 xl:w-80 self-center">
      <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-4">
        2º Encontro Nacional pela Soberania Digital
      </p>
      <h1 class="text-[#FFD400] text-4xl md:text-6xl font-black uppercase leading-none mb-2">18 E 19<br />DE MAIO</h1>
      <p class="text-[#E7E7D8] text-2xl md:text-4xl font-black uppercase leading-tight mb-8">BRASÍLIA / DF</p>
      <div class="flex flex-col gap-3">
        <a
          href={conf.callToAction.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center min-h-[52px] bg-[#E31B23] hover:bg-[#b01015] text-white font-black text-lg uppercase py-4 px-8 border-l-4 border-[#FFD400] transition-colors"
        >
          Inscreva-se
        </a>
        <a
          href="#programacao"
          class="inline-flex items-center justify-center min-h-[48px] border border-[#333] text-[#E7E7D8] hover:border-[#FFD400] hover:text-[#FFD400] font-bold uppercase py-3 px-6 transition-colors text-sm"
        >
          Ver Programação ↓
        </a>
        <a
          href={asset('/encontro.ics')}
          download
          class="inline-flex items-center justify-center gap-2 min-h-[44px] border border-[#333] text-[#E7E7D8] hover:border-[#FFD400] hover:text-[#FFD400] font-bold uppercase py-2 px-4 transition-colors text-xs"
        >
          <span aria-hidden="true">↓</span> Adicionar à agenda (.ics)
        </a>
      </div>
    </div>
  </div>
</section>
