---
import type { PartnerOrg, PartnersGrid } from '~/types/evento';

export interface Props {
  partnersGrid: PartnersGrid;
  asset: (p: string) => string;
}
const { partnersGrid, asset } = Astro.props;
---

<section class="bg-white dark:bg-[#080808] py-16 md:py-20 border-t border-[#e5e7eb] dark:border-[#1a1a1a]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row gap-10 sm:gap-16 mb-12 justify-center items-start">
      <div class="text-center flex-1">
        <p class="text-[#FFD400] text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-6">Realização</p>
        <div class="flex justify-center gap-8 flex-wrap items-center">
          {
            partnersGrid.realizacao.map((org: PartnerOrg) =>
              org.logo ? (
                <a
                  href={org.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center"
                >
                  <img
                    src={asset(org.logo)}
                    alt={org.nome}
                    width="240"
                    height="96"
                    loading="lazy"
                    decoding="async"
                    class={`h-16 sm:h-24 w-auto max-w-[70vw] sm:max-w-none object-contain transition-opacity hover:opacity-80 ${org.logoType === 'mono' ? 'dark:brightness-0 dark:invert' : 'dark:opacity-80'}`}
                  />
                </a>
              ) : (
                <span class="text-[#555] dark:text-[#777] font-bold text-sm">{org.nome}</span>
              )
            )
          }
        </div>
      </div>
      <div class="text-center flex-1">
        <p class="text-[#FFD400] text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-6">Apoio Institucional</p>
        <div class="flex justify-center gap-8 flex-wrap items-center">
          {
            partnersGrid.patrocinio.map((org: PartnerOrg) =>
              org.logo ? (
                <a
                  href={org.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center"
                >
                  <img
                    src={asset(org.logo)}
                    alt={org.nome}
                    width="240"
                    height="96"
                    loading="lazy"
                    decoding="async"
                    class={`h-16 sm:h-24 w-auto max-w-[70vw] sm:max-w-none object-contain transition-opacity hover:opacity-80 ${org.logoType === 'mono' ? 'dark:brightness-0 dark:invert' : 'dark:opacity-80'}`}
                  />
                </a>
              ) : (
                <span class="text-[#555] dark:text-[#777] font-bold text-sm">{org.nome}</span>
              )
            )
          }
        </div>
      </div>
    </div>

    <div class="mb-12 text-center border-t border-[#e5e7eb] dark:border-[#1a1a1a] pt-10">
      <p class="text-[#777] dark:text-[#555] text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-6">
        Organização
      </p>
      <div class="flex justify-center gap-8 flex-wrap items-center">
        {
          [...partnersGrid.producao].reverse().map((org: PartnerOrg) =>
            org.logo ? (
              <a
                href={org.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center"
              >
                <img
                  src={asset(org.logo)}
                  alt={org.nome}
                  width="200"
                  height="64"
                  loading="lazy"
                  decoding="async"
                  class={`h-12 sm:h-16 w-auto max-w-[60vw] sm:max-w-none object-contain transition-opacity hover:opacity-80 ${org.logoType === 'mono' ? 'dark:brightness-0 dark:invert' : 'dark:opacity-80'}`}
                />
              </a>
            ) : (
              <span class="text-[#555] dark:text-[#777] font-bold text-sm">{org.nome}</span>
            )
          )
        }
      </div>
    </div>

    <div class="border-t border-[#e5e7eb] dark:border-[#1a1a1a] pt-10">
      <p class="text-[#777] dark:text-[#555] text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-3">Apoio</p>
      <div class="flex flex-wrap gap-2">
        {
          partnersGrid.apoio.map((org: PartnerOrg) => (
            <span class="border border-[#e5e7eb] dark:border-[#222] text-[#555] dark:text-[#777] px-3 py-1.5 text-xs">
              {org.nome}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
