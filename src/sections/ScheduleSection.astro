---
import type { DiaData } from '~/types/schedule';
import ViewTabs from '~/components/schedule/ViewTabs.astro';
import DayTabs from '~/components/schedule/DayTabs.astro';
import ScheduleGrid from '~/components/schedule/ScheduleGrid.astro';
import ScheduleList from '~/components/schedule/ScheduleList.astro';
import SpeakerList from '~/components/schedule/SpeakerList.astro';

export interface Props {
  diasData: DiaData[];
}
const { diasData } = Astro.props;
---

<section id="programacao" class="bg-[#0d0d0d] py-10 md:py-14">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="mb-8">
      <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-2">Programação Completa</p>
      <h2 class="text-white text-3xl md:text-5xl font-black uppercase leading-tight">O que acontece</h2>
    </div>

    <ViewTabs />

    <!-- VIEW: GRADE -->
    <div class="view-panel active" id="view-grade" role="tabpanel" aria-labelledby="view-tab-grade" tabindex="0">
      <DayTabs dias={diasData} viewTarget="grade" />
      {
        diasData.map((dia, di) => (
          <div
            class={`day-panel${di === 0 ? ' active' : ''}`}
            id={`grade-${dia.key}`}
            role="tabpanel"
            aria-labelledby={`day-tab-grade-${dia.key}`}
            tabindex="0"
          >
            <ScheduleGrid dia={dia} />
          </div>
        ))
      }
    </div>

    <!-- VIEW: SESSÕES -->
    <div class="view-panel" id="view-sessoes" role="tabpanel" aria-labelledby="view-tab-sessoes" tabindex="0">
      <DayTabs dias={diasData} viewTarget="sessoes" />
      {
        diasData.map((dia, di) => (
          <div
            class={`day-panel${di === 0 ? ' active' : ''}`}
            id={`sessoes-${dia.key}`}
            role="tabpanel"
            aria-labelledby={`day-tab-sessoes-${dia.key}`}
            tabindex="0"
          >
            <ScheduleList dia={dia} />
          </div>
        ))
      }
    </div>

    <!-- VIEW: PALESTRANTES -->
    <div class="view-panel" id="view-palestrantes" role="tabpanel" aria-labelledby="view-tab-palestrantes" tabindex="0">
      <DayTabs dias={diasData} viewTarget="palestrantes" />
      {
        diasData.map((dia, di) => (
          <div
            class={`day-panel${di === 0 ? ' active' : ''}`}
            id={`palestrantes-${dia.key}`}
            role="tabpanel"
            aria-labelledby={`day-tab-palestrantes-${dia.key}`}
            tabindex="0"
          >
            <SpeakerList dia={dia} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .view-panel {
    display: none;
  }
  .view-panel.active {
    display: block;
  }
  .day-panel {
    display: none;
  }
  .day-panel.active {
    display: block;
  }
</style>

<script>
  import { initScheduleTabs } from '~/scripts/schedule-tabs';
  initScheduleTabs();
</script>
