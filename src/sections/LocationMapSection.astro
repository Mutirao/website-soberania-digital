---
import type { EventoLocation } from '~/types/evento';

export interface Props {
  location: EventoLocation;
}
const { location } = Astro.props;
---

<span class="block h-1 flex-shrink-0 bg-gradient-to-r from-[#E31B23] from-60% to-[#FFD400] to-60%"></span>
<section id="local" class="bg-white dark:bg-[#010101] py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-3">Local do Evento</p>
      <h2 class="text-[#010101] dark:text-white text-3xl md:text-5xl font-black uppercase leading-tight mb-2">
        {location.name}
      </h2>
      <p class="text-[#E7E7D8] text-base leading-relaxed">{location.address}</p>
      <p class="text-[#666666] dark:text-[#9ca3af] text-[0.8125rem] leading-relaxed mt-1">{location.room}</p>
    </div>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <div
      id="osm-map"
      class="w-full border-[#e5e7eb] dark:border-[#1f2937] border shadow h-[260px] sm:h-[340px] md:h-[420px]"
    >
    </div>
    <div class="flex flex-wrap gap-3 mt-4 justify-center text-xs">
      {
        [
          { color: '#E31B23', label: 'Local do Encontro' },
          { color: '#45a2ca', label: 'Hotéis' },
          { color: '#77b978', label: 'Aeroporto' },
          { color: '#FFD400', label: 'Rodoviária' },
        ].map((l) => (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-[#f9f9f9] dark:bg-[#111111] border border-[#ebebeb] dark:border-[#1e1e1e] text-[#292929] dark:text-[#d1d5db]">
            <span class="w-3 h-3 rounded-full inline-block flex-shrink-0" style={`background:${l.color}`} />
            {l.label}
          </span>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { initMap } from '~/scripts/leaflet-map';
  initMap();
</script>
