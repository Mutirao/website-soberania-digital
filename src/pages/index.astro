---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import evento from '~/data/evento.json';
import programacao from '~/data/programacao-gerado.json';
import assinaturas from '~/data/assinaturas.json';
const { conf, about, location, hotels, community, partnersGrid } = evento;

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const asset = (p: string) => base + (p.startsWith('/') ? p : '/' + p);

// ── schedule helpers ────────────────────────────────────────────────────────
const diasMap: Record<string, string> = {
  '18/05 Seg': 'dia1',
  '19/05 Ter': 'dia2',
};

function formatTime(t: string) {
  if (!t) return '';
  const [h, m] = t.split(':');
  const hi = parseInt(h);
  if (isNaN(hi)) return t;
  return m && m !== '00' ? `${hi}h${m}` : `${hi}h`;
}

function isConfirmed(status: string) {
  return (status ?? '').toUpperCase().includes('CONFIRMAD');
}

function parseMin(t: string): number | null {
  if (!t || t.toLowerCase().includes('tarde') || t === '?') return null;
  const [h, m] = t.trim().split(':').map(n => parseInt(n));
  if (isNaN(h)) return null;
  return h * 60 + (isNaN(m) ? 0 : m);
}

function minToTime(m: number): string {
  const h = Math.floor(m / 60), min = m % 60;
  return min === 0 ? `${h}h` : `${h}h${String(min).padStart(2, '0')}`;
}

const BASE_MIN  = 8 * 60;
const SLOT_MIN  = 15;
const SLOT_H_PX = 36;
const locaisOrder = ['Anfiteatro Central', 'Auditório 70 lug.', 'Auditório 50 lug.', 'Auditório 30 lug.'];
const locaisShort = ['Anfiteatro', 'Aud. 70', 'Aud. 50', 'Aud. 30'];

function toRow(min: number): number {
  return Math.max(2, Math.round((min - BASE_MIN) / SLOT_MIN) + 2);
}

const diasConf = [
  { key: 'dia1', diaVal: '18/05 Seg', label: '18 de Maio', color: '#CC2200', endMin: 20 * 60 + 30 },
  { key: 'dia2', diaVal: '19/05 Ter', label: '19 de Maio', color: '#1a5c2a', endMin: 20 * 60 },
];

const sessoes = programacao.sessoes as any[];

const diasData = diasConf.map(dConf => {
  const ss = sessoes.filter((s: any) => s.dia === dConf.diaVal);
  const locaisPresentes = locaisOrder.filter(l => ss.some((s: any) => s.local === l));

  const processed = ss.map((s: any) => {
    const startMin = parseMin(s.inicio);
    if (startMin === null) return { ...s, _startRow: -1, _endRow: -1, _startMin: null };
    let endMin = parseMin(s.fim);
    if (endMin === null) {
      const sameLocalLater = ss
        .filter((x: any) => x.local === s.local && parseMin(x.inicio) !== null && (parseMin(x.inicio) as number) > startMin)
        .map((x: any) => parseMin(x.inicio) as number)
        .sort((a: number, b: number) => a - b);
      endMin = sameLocalLater[0] ?? Math.min(startMin + 60, dConf.endMin);
    }
    return { ...s, _startMin: startMin, _endMin: endMin,
      _startRow: toRow(startMin), _endRow: Math.max(toRow(startMin) + 1, toRow(endMin)) };
  });

  const nSlots = Math.ceil((dConf.endMin - BASE_MIN) / SLOT_MIN);
  const timeAxis: { row: number; label: string; isHour: boolean }[] = [];
  for (let m = BASE_MIN; m <= dConf.endMin; m += 30) {
    timeAxis.push({ row: toRow(m), label: minToTime(m), isHour: m % 60 === 0 });
  }

  const palMap: Record<string, { nome: string; org: string; sessoes: string[] }> = {};
  for (const s of ss) {
    for (const p of (s.palestrantes || [])) {
      if (!isConfirmed(p.status)) continue;
      const key = p.nome.trim();
      if (!palMap[key]) palMap[key] = { nome: p.nome, org: p.organizacao || '', sessoes: [] };
      if (!palMap[key].sessoes.includes(s.titulo)) palMap[key].sessoes.push(s.titulo);
    }
  }
  const palList = Object.values(palMap).sort((a, b) => a.nome.localeCompare(b.nome, 'pt-BR'));

  const sessoesList = [...processed]
    .filter((s: any) => s._startMin !== null)
    .sort((a: any, b: any) => (a._startMin as number) - (b._startMin as number));

  return { ...dConf, locaisPresentes, processed, nSlots, timeAxis, palList, sessoesList };
});

const metadata = {
  title: `${conf.name} — Soberania.Digital`,
  ignoreTitleTemplate: true,
  description: `${conf.date} · ${conf.venue}. ${conf.description}`,
};
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Overpass:wght@300;400;700;900&family=Barlow+Condensed:wght@400;700;900&display=swap');

  /* ── view tabs (grade/sessões/palestrantes) ── */
  .view-tab {
    font-family: var(--font-grade); font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px;
    text-transform: uppercase; padding: 8px 14px; min-height: 44px;
    border: 1px solid var(--color-enc-border); background: transparent; color: var(--color-enc-muted);
    cursor: pointer; transition: all 0.15s;
  }
  @media (min-width: 400px) {
    .view-tab { font-size: 0.85rem; padding: 10px 18px; }
  }
  .view-tab:hover { color: #ccc; border-color: var(--color-enc-muted); }
  .view-tab.active { background: var(--color-sinal); color: #000; border-color: var(--color-sinal); font-weight: 900; }

  .day-tab {
    font-family: var(--font-grade); font-weight: 900; font-size: 0.95rem; text-transform: uppercase;
    letter-spacing: 1px; padding: 10px 20px; min-height: 44px; border: none;
    cursor: pointer; opacity: 0.45; transition: opacity 0.15s; color: white;
    flex: 1 1 0; min-width: 0; text-align: center;
  }
  .day-tab.active { opacity: 1; }
  @media (max-width: 400px) {
    .day-tab { padding: 8px 10px; font-size: 0.78rem; letter-spacing: 0.5px; }
  }

  .view-panel { display: none; }
  .view-panel.active { display: block; }
  .day-panel { display: none; }
  .day-panel.active { display: block; }

  /* ── time grid ── */
  .time-grid-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1px solid var(--color-linha); scroll-behavior: smooth; }
  .time-grid { display: grid; min-width: 480px; }
  .tg-corner { background: var(--color-grade); position: sticky; left: 0; z-index: 20; }
  .tg-room-hdr {
    font-family: var(--font-grade); font-weight: 900;
    font-size: 0.92rem; text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--color-enc-label); padding: 10px 6px; border-bottom: 1px solid #252525;
    border-left: 1px solid var(--color-enc-line); background: var(--color-enc-input); display: flex; align-items: center;
  }
  @media (min-width: 640px) {
    .tg-room-hdr { font-size: 1rem; padding: 10px 8px; }
  }
  .tg-time {
    font-family: var(--font-grade); font-size: 0.82rem; color: var(--color-enc-border);
    background: var(--color-grade); position: sticky; left: 0; z-index: 10;
    display: flex; align-items: flex-start; padding: 3px 5px 0;
    border-right: 1px solid var(--color-enc-line);
  }
  @media (min-width: 640px) {
    .tg-time { font-size: 1rem; padding: 3px 6px 0; }
  }
  .tg-time.is-hour { color: var(--color-enc-muted); border-top: 1px solid var(--color-linha); }
  .tg-time.is-half { border-top: 1px solid var(--color-enc-grid-bg); }
  .tg-hour-line { border-top: 1px solid var(--color-enc-line); pointer-events: none; z-index: 1; }
  .tg-half-line { border-top: 1px solid #131313; pointer-events: none; z-index: 1; }
  .tg-session {
    margin: 2px 3px; padding: 5px 7px;
    border-left: 3px solid var(--dc, #CC2200); background: var(--color-enc-card);
    overflow: hidden; cursor: default; z-index: 5;
    font-size: 0.82rem; line-height: 1.35; position: relative; transition: background 0.1s;
  }
  @media (min-width: 640px) {
    .tg-session { padding: 6px 8px; font-size: 1rem; }
  }
  .tg-session:hover { background: #1c1c1c; }
  .tg-session.intervalo { background: var(--color-enc-grid); border-left-color: #222; }
  .tg-session.especial { background: var(--color-enc-especial); border-left-color: var(--color-sinal); }
  .tg-time-badge {
    font-family: var(--font-grade); font-weight: 700; font-size: 0.82rem;
    background: var(--dc, #CC2200); color: white; padding: 1px 5px; border-radius: 2px;
    display: inline-block; margin-bottom: 3px;
  }
  @media (min-width: 640px) {
    .tg-time-badge { font-size: 1rem; padding: 1px 5px; margin-bottom: 3px; }
  }
  .tg-session.intervalo .tg-time-badge { background: #252525; color: var(--color-enc-muted); }
  .tg-session.especial  .tg-time-badge { background: var(--color-sinal); color: #000; }
  .tg-title {
    display: block; font-family: var(--font-grade); font-weight: 700; font-size: 0.92rem; color: #ddd; line-height: 1.25; margin-bottom: 2px;
  }
  @media (min-width: 640px) {
    .tg-title { font-size: 1.25rem; margin-bottom: 3px; }
  }
  .tg-session.intervalo .tg-title { color: var(--color-enc-border); font-weight: 400; }
  .tg-session.especial  .tg-title { color: var(--color-sinal); }
  .tg-speakers { display: block; font-size: 0.82rem; color: var(--color-enc-muted); line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  @media (min-width: 640px) {
    .tg-speakers { font-size: 1.25rem; }
  }

  /* ── sessions list ── */
  .sl-session { display: flex; gap: 12px; padding: 12px 14px; background: var(--color-enc-card); border-left: 3px solid var(--dc, #CC2200); margin-bottom: 2px; align-items: flex-start; }
  .sl-session.intervalo { border-left-color: #222; background: var(--color-enc-grid); }
  .sl-session.especial  { border-left-color: var(--color-sinal); background: var(--color-enc-especial); }
  .sl-time {
    font-family: var(--font-grade); font-weight: 700; font-size: 0.9rem;
    background: var(--dc, #CC2200); color: white; padding: 2px 8px; border-radius: 2px;
    flex-shrink: 0; min-width: 42px; text-align: center; white-space: nowrap; margin-top: 1px;
  }
  @media (min-width: 640px) {
    .sl-time { font-size: 1rem; padding: 2px 8px; min-width: 44px; }
  }
  .sl-session.intervalo .sl-time { background: #252525; color: var(--color-enc-muted); }
  .sl-session.especial  .sl-time { background: var(--color-sinal); color: #000; }
  .sl-body { flex: 1; min-width: 0; }
  .sl-title { font-family: var(--font-grade); font-weight: 700; font-size: 1.05rem; color: #e0e0e0; line-height: 1.25; margin-bottom: 3px; display: block; }
  @media (min-width: 640px) {
    .sl-title { font-size: 1.25rem; }
  }
  .sl-session.intervalo .sl-title { color: var(--color-enc-border); font-weight: 400; }
  .sl-session.especial  .sl-title { color: var(--color-sinal); }
  .sl-local { font-size: 0.88rem; color: var(--color-enc-border); font-style: italic; margin-bottom: 4px; display: block; }
  @media (min-width: 640px) {
    .sl-local { font-size: 1rem; }
  }
  .sl-chips { display: flex; flex-wrap: wrap; gap: 5px; }
  .sl-chip { background: var(--color-chip-bg); border: 1px solid var(--color-chip-border); color: var(--color-chip-text); font-size: 0.85rem; padding: 3px 8px; border-radius: 10px; }
  @media (min-width: 640px) {
    .sl-chip { font-size: 1rem; padding: 2px 8px; }
  }

  /* ── palestrantes ── */
  .pal-item { display: flex; gap: 12px; padding: 12px 14px; border-bottom: 1px solid var(--color-enc-grid-bg); align-items: flex-start; }
  .pal-avatar {
    width: 44px; height: 44px; border-radius: 50%; background: var(--color-enc-line); border: 1px solid #2a2a2a;
    flex-shrink: 0; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-grade); font-weight: 900; font-size: 1.1rem; color: var(--color-enc-border);
  }
  .pal-nome { font-family: var(--font-grade); font-weight: 700; font-size: 1.05rem; color: #e0e0e0; display: block; line-height: 1.2; }
  @media (min-width: 640px) {
    .pal-nome { font-size: 1.25rem; }
  }
  .pal-org { font-size: 0.88rem; color: var(--color-enc-muted); display: block; margin-bottom: 3px; }
  @media (min-width: 640px) {
    .pal-org { font-size: 1rem; }
  }
  .pal-sess { font-size: 0.88rem; color: var(--color-sinal); display: block; line-height: 1.3; }
  @media (min-width: 640px) {
    .pal-sess { font-size: 1rem; }
  }

  /* ── media collage ── */
  @media (min-width: 640px) {
    .collage-grid { grid-auto-rows: 220px; }
    .collage-grid > div { aspect-ratio: unset; }
  }

  /* ── period header ── */
  .period-hdr { display: flex; align-items: center; gap: 8px; padding: 14px 0 6px; }
  .period-hdr span { font-size: 1rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--color-enc-muted); }
  .period-line { flex: 1; height: 1px; background: var(--color-linha); }
</style>

<Layout metadata={metadata}>
  <div class="enc overflow-x-hidden">

<!-- ═══════════════════════════════════════════════════════════════
     1. HERO — Identidade + CTA imediato
     ═══════════════════════════════════════════════════════════════ -->
    <section class="bg-white dark:bg-enc">

      <!-- mobile hero: imagem de banner full-width -->
      <div class="md:hidden">
        <img
          src={asset('/banner-encontro-1080.png')}
          alt="2º Encontro Nacional pela Soberania Digital — 18 e 19 de Maio, Brasília"
          class="w-full block"
          loading="eager"
        />
        <div class="px-5 py-8 text-center">
          <p class="text-white text-lg font-black uppercase leading-tight mb-2">
            O Brasil vai decidir<br/>seu futuro digital.
          </p>
          <p class="text-sinal text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-4">
            2º Encontro Nacional pela Soberania Digital
          </p>
          <div class="flex flex-wrap gap-3 justify-center mb-6">
            <div class="text-center">
              <p class="text-sinal text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-0.5">Quando</p>
              <p class="text-white font-bold text-lg">18 e 19 de Maio</p>
            </div>
            <div class="text-center">
              <p class="text-sinal text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-0.5">Onde</p>
              <p class="text-white font-bold text-lg">Brasília / DF</p>
            </div>
          </div>
          <a href={conf.callToAction.link} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center min-h-[52px] bg-cta hover:bg-cta-hover text-white font-black text-lg uppercase py-3 px-8 border-l-4 border-sinal transition-colors w-full">
            Inscreva-se
          </a>
        </div>
      </div>

      <!-- desktop hero: banner à esquerda, data + CTA à direita -->
      <div class="hidden md:flex items-center gap-10 max-w-6xl mx-auto px-6 py-12 lg:py-16">
        <div class="flex-1 min-w-0">
          <img
            src={asset('/banner-encontro-1080.png')}
            alt="2º Encontro Nacional pela Soberania Digital"
            class="w-full max-h-[60vh] object-contain block"
            loading="eager"
          />
        </div>
        <div class="flex-shrink-0 w-72 xl:w-80 self-center">
          <p class="text-white text-xl md:text-2xl font-black uppercase leading-tight mb-3">
            O Brasil vai decidir<br/>seu futuro digital.
          </p>
          <p class="text-sinal text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-4">
            2º Encontro Nacional pela Soberania Digital
          </p>
          <h1 class="text-sinal text-4xl md:text-6xl font-black uppercase leading-none mb-2">18 E 19<br/>DE MAIO</h1>
          <p class="text-quente text-2xl md:text-4xl font-black uppercase leading-tight mb-8">BRASÍLIA / DF</p>
          <div class="flex flex-col gap-3">
            <a href={conf.callToAction.link} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center justify-center min-h-[52px] bg-cta hover:bg-cta-hover text-white font-black text-lg uppercase py-4 px-8 border-l-4 border-sinal transition-colors">
              Inscreva-se
            </a>
            <a href="#programacao"
              class="inline-flex items-center justify-center min-h-[48px] border border-enc-border text-quente hover:border-sinal hover:text-sinal font-bold uppercase py-3 px-6 transition-colors text-sm">
              Ver Programação ↓
            </a>
            <a href={asset('/encontro.ics')} download
              class="inline-flex items-center justify-center min-h-[44px] text-enc-muted-alt hover:text-enc-label font-bold uppercase py-2 px-4 transition-colors text-xs">
              ↓ Adicionar à agenda (.ics)
            </a>
          </div>
        </div>
      </div>
    </section>

    <span class="enc-stripe"></span>

<!-- ═══════════════════════════════════════════════════════════════
     2. A VERDADE QUE NINGUÉM TE CONTA
     ═══════════════════════════════════════════════════════════════ -->
    <section class="bg-surface dark:bg-grade py-16 md:py-20 intersect-once intersect-quarter motion-safe:opacity-0 motion-safe:intersect:animate-fade">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="md:flex items-start gap-12 lg:gap-20">
          <div class="md:basis-2/5 mb-8 md:mb-0">
            <p class="text-cta text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-4">A verdade que ninguém te conta</p>
            <h2 class="text-enc dark:text-white text-3xl md:text-5xl font-black uppercase leading-tight mb-4">
              Você acha que<br/>o Brasil é<br/>soberano?
            </h2>
            <p class="text-enc-label text-base leading-relaxed">
              Nossa economia, democracia e comunicação dependem de plataformas e infraestruturas estrangeiras. Isso não é tecnologia. <strong class="text-sinal">É poder.</strong>
            </p>
          </div>
          <div class="md:basis-3/5 min-w-0 space-y-4">
            <div class="bg-card dark:bg-enc-card border border-linha-light dark:border-linha p-5 flex gap-5 items-start">
              <span class="flex-shrink-0 w-14 h-14 flex items-center justify-center bg-cta/10 text-cta"><Icon name="tabler:cloud-off" class="w-8 h-8" /></span>
              <div>
                <h3 class="text-sinal text-base font-black uppercase mb-1">Seus Dados Estão Fora do País</h3>
                <p class="text-enc-muted-alt dark:text-enc-label text-sm leading-relaxed">Fora da nossa lei. Fora do nosso controle. Empresas estrangeiras armazenam e monetizam informações de milhões de brasileiros.</p>
              </div>
            </div>
            <div class="bg-card dark:bg-enc-card border border-linha-light dark:border-linha p-5 flex gap-5 items-start">
              <span class="flex-shrink-0 w-14 h-14 flex items-center justify-center bg-sinal/10 text-sinal"><Icon name="tabler:code" class="w-8 h-8" /></span>
              <div>
                <h3 class="text-sinal text-base font-black uppercase mb-1">Seus Algoritmos São Controlados por Estrangeiros</h3>
                <p class="text-enc-label text-sm leading-relaxed">Big Techs decidem o que você vê, o que é amplificado e o que é silenciado — sem qualquer controle democrático.</p>
              </div>
            </div>
            <div class="bg-card dark:bg-enc-card border border-linha-light dark:border-linha p-5 flex gap-5 items-start">
              <span class="flex-shrink-0 w-14 h-14 flex items-center justify-center bg-azimute/10 text-azimute"><Icon name="tabler:eye-exclamation" class="w-8 h-8" /></span>
              <div>
                <h3 class="text-sinal text-base font-black uppercase mb-1">Sua Informação É Manipulada Todos os Dias</h3>
                <p class="text-enc-label text-sm leading-relaxed">Censura algorítmica, desinformação e manipulação do debate público moldam opiniões e decisões no Brasil.</p>
              </div>
            </div>
            <blockquote class="border-l-4 border-sinal pl-6 mt-6">
              <p class="text-white text-xl md:text-2xl font-black uppercase leading-tight">"Quem controla o digital, controla o país."</p>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

<!-- ═══════════════════════════════════════════════════════════════
     3. É HORA DE AGIR
     ═══════════════════════════════════════════════════════════════ -->

    <!-- 3a. INPUTS — Quem está nessa luta -->
    <section class="bg-white dark:bg-enc py-16 md:py-20 border-y border-enc-line intersect-once intersect-quarter motion-safe:opacity-0 motion-safe:intersect:animate-fade">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">

        <p class="text-cta text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-3">É hora de agir</p>
        <h3 class="text-enc dark:text-white text-2xl md:text-3xl font-black uppercase leading-tight mb-10">Quem está nessa luta</h3>

        <!-- Big number -->
        <div class="mb-10">
          <p id="inscritos-count" class="text-sinal text-7xl md:text-8xl font-black leading-none tabular-nums">—</p>
          <p class="text-enc-muted-alt dark:text-enc-label text-sm font-bold uppercase tracking-[0.12em] mt-3">pessoas já assinaram pela soberania digital</p>
        </div>

        <!-- Divisor -->
        <div class="flex items-center gap-4 mb-10">
          <div class="flex-1 h-px bg-enc-border dark:bg-enc-line"></div>
          <p class="text-enc-muted-alt text-[0.6875rem] font-bold uppercase tracking-[0.12em] flex-shrink-0">com o apoio de</p>
          <div class="flex-1 h-px bg-enc-border dark:bg-enc-line"></div>
        </div>

        <!-- Logos -->
        <div id="quem-logos" class="flex flex-wrap gap-4 items-center justify-center">
          {partnersGrid.apoio.map((org: any) => (
            <span class="border border-enc-border text-gray-300 px-5 py-3 font-bold text-sm uppercase tracking-wide hover:border-sinal hover:text-sinal transition-colors">
              {org.nome}
            </span>
          ))}
        </div>

      </div>
    </section>

    <!-- 3b. ACTIVITIES — Programação completa (grade/sessões/palestrantes) -->
    <section id="programacao" class="bg-surface dark:bg-grade py-16 md:py-20 intersect-once intersect-quarter motion-safe:opacity-0 motion-safe:intersect:animate-fade">
