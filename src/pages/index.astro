                      src={asset(org.logo)}
                      alt={org.nome}
                      class={`h-16 sm:h-24 w-auto max-w-[70vw] sm:max-w-none object-contain transition-opacity hover:opacity-80 ${org.logoType === 'mono' ? 'dark:brightness-0 dark:invert' : 'dark:opacity-80'}`}
                    />
                  </a>
                ) : (
                  <span class="text-[#555] dark:text-[#777] font-bold text-sm">{org.nome}</span>
                )
              ))}
            </div>
          </div>
          <div class="text-center flex-1">
            <p class="text-[#E31B23] text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-6">Apoio Institucional</p>
            <div class="flex justify-center gap-8 flex-wrap items-center">
              {partnersGrid.patrocinio.map((org: any) => (
                org.logo ? (
                  <a href={org.url} target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center justify-center">
                    <img
                      src={asset(org.logo)}
                      alt={org.nome}
                      class={`h-16 sm:h-24 w-auto max-w-[70vw] sm:max-w-none object-contain transition-opacity hover:opacity-80 ${org.logoType === 'mono' ? 'dark:brightness-0 dark:invert' : 'dark:opacity-80'}`}
                    />
                  </a>
                ) : (
                  <span class="text-[#555] dark:text-[#777] font-bold text-sm">{org.nome}</span>
                )
              ))}
            </div>
          </div>
        </div>

        <!-- LINHA 2: ORGANIZAÇÃO -->
        <div class="mb-12 text-center border-t border-[#e5e7eb] dark:border-[#1a1a1a] pt-10">
          <p class="text-[#777] dark:text-[#555] text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-6">Organização</p>
          <div class="flex justify-center gap-8 flex-wrap items-center">
            {[...partnersGrid.producao].reverse().map((org: any) => (
              org.logo ? (
                <a href={org.url} target="_blank" rel="noopener noreferrer"
                  class="inline-flex items-center justify-center">
                  <img
                    src={asset(org.logo)}
                    alt={org.nome}
                    class={`h-12 sm:h-16 w-auto max-w-[60vw] sm:max-w-none object-contain transition-opacity hover:opacity-80 ${org.logoType === 'mono' ? 'dark:brightness-0 dark:invert' : 'dark:opacity-80'}`}
                  />
                </a>
              ) : (
                <span class="text-[#555] dark:text-[#777] font-bold text-sm">{org.nome}</span>
              )
            ))}
          </div>
        </div>

        <!-- LINHA 3: APOIO -->
        <div class="border-t border-[#e5e7eb] dark:border-[#1a1a1a] pt-10">
          <p class="text-[#777] dark:text-[#555] text-[0.6875rem] font-bold uppercase tracking-[0.12em] mb-3">Apoio</p>
          <div class="flex flex-wrap gap-2">
            {partnersGrid.apoio.map((org: any) => (
              <span class="border border-[#e5e7eb] dark:border-[#222] text-[#555] dark:text-[#777] px-3 py-1.5 text-xs">
                {org.nome}
              </span>
            ))}
          </div>
        </div>

      </div>
    </section>

  </div>
</Layout>

<script>
fetch('/encontro/api/dados')
  .then(r => r.ok ? r.json() : null)
  .then(dados => {
    if (!dados) return;
    if (dados.inscritos != null) {
      const el = document.getElementById('inscritos-count');
      if (el) el.textContent = dados.inscritos.toLocaleString('pt-BR');
      const timeEl = document.getElementById('inscritos-time');
      if (timeEl) {
        const d = new Date(dados.atualizadoEm);
        timeEl.textContent = 'atualizado em ' + d.toLocaleDateString('pt-BR', {
          day: '2-digit', month: '2-digit', year: 'numeric',
          hour: '2-digit', minute: '2-digit',
        });
      }
    }
  })
  .catch(() => {});
</script>
