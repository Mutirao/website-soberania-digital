---
import Layout from '~/layouts/PageLayout.astro';
import evento from '~/data/evento.json';
import programacao from '~/data/programacao.json';
import assinaturas from '~/data/assinaturas.json';

import { buildScheduleData } from '~/lib/schedule';

import HeroSection from '~/sections/HeroSection.astro';
import AboutSection from '~/sections/AboutSection.astro';
import ScheduleSection from '~/sections/ScheduleSection.astro';
import InitiativesSection from '~/sections/InitiativesSection.astro';
import RegistrationCTASection from '~/sections/RegistrationCTASection.astro';
import LocationMapSection from '~/sections/LocationMapSection.astro';
import RegistrationFormSection from '~/sections/RegistrationFormSection.astro';
import PartnersSection from '~/sections/PartnersSection.astro';

const { conf, about, location, partnersGrid } = evento;

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const asset = (p: string) => base + (p.startsWith('/') ? p : '/' + p);

const diasData = buildScheduleData(programacao.sessoes as any[]);

const metadata = {
  title: `${conf.name} — Soberania.Digital`,
  ignoreTitleTemplate: true,
  description: `${conf.date} · ${conf.venue}. ${conf.description}`,
};
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Overpass:wght@300;400;700;900&family=Barlow+Condensed:wght@400;700;900&display=swap');
  .enc {
    font-family: 'Overpass', Helvetica, Arial, sans-serif;
  }
</style>

<Layout metadata={metadata}>
  <div class="enc overflow-x-hidden">
    <HeroSection conf={conf} asset={asset} />
    <AboutSection conf={conf} about={about} />
    <ScheduleSection diasData={diasData} />
    <InitiativesSection />
    <RegistrationCTASection conf={conf} assinaturas={assinaturas} />
    <LocationMapSection location={location} />
    <RegistrationFormSection conf={conf} />
    <PartnersSection partnersGrid={partnersGrid} asset={asset} />
  </div>
</Layout>

<script>
  fetch('/encontro/api/dados')
    .then((r) => (r.ok ? r.json() : null))
    .then((dados) => {
      if (!dados) return;
      if (dados.inscritos != null) {
        const el = document.getElementById('inscritos-count');
        if (el) el.textContent = dados.inscritos.toLocaleString('pt-BR');
        const timeEl = document.getElementById('inscritos-time');
        if (timeEl && dados.atualizadoEm) {
          const d = new Date(dados.atualizadoEm);
          timeEl.textContent =
            'atualizado em ' +
            d.toLocaleDateString('pt-BR', {
              day: '2-digit',
              month: '2-digit',
              year: 'numeric',
              hour: '2-digit',
              minute: '2-digit',
            });
        }
      }
    })
    .catch(() => {});
</script>
