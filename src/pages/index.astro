    <!-- Form submit handler 
    <script is:inline>
      (function () {
        var form = document.getElementById('form-inscricao');
        var sucesso = document.getElementById('form-sucesso');
        if (!form) return;

        form.addEventListener('submit', function (e) {
          // Only intercept if not Netlify (no action attr means Netlify handles it)
          // When on Netlify, the redirect/success is handled by Netlify;
          // this fallback shows success state for non-Netlify environments.
          if (!form.hasAttribute('data-netlify-confirmed')) {
            e.preventDefault();
            var data = new FormData(form);
            fetch('/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: new URLSearchParams(data).toString(),
            }).then(function () {
              form.style.display = 'none';
              sucesso.classList.remove('hidden');
            }).catch(function () {
              // Fallback: just show success (non-Netlify env)
              form.style.display = 'none';
              sucesso.classList.remove('hidden');
            });
          }
        });
      })();
    </script>

    <!-- Schedule tabs script -->
    <script is:inline>
      (function () {
        document.querySelectorAll('.view-tab').forEach(function (tab) {
          tab.addEventListener('click', function () {
            var view = this.getAttribute('data-view');
            document.querySelectorAll('.view-tab').forEach(function (t) {
              t.classList.remove('active'); t.setAttribute('aria-selected', 'false');
            });
            document.querySelectorAll('.view-panel').forEach(function (p) { p.classList.remove('active'); });
            this.classList.add('active'); this.setAttribute('aria-selected', 'true');
            var panel = document.getElementById('view-' + view);
            if (panel) panel.classList.add('active');
          });
        });

        document.querySelectorAll('.day-tab').forEach(function (tab) {
          tab.addEventListener('click', function () {
            var day = this.getAttribute('data-day');
            var viewTarget = this.getAttribute('data-view-target');
            var vp = this.closest('.view-panel');
            if (vp) vp.querySelectorAll('.day-tab').forEach(function (t) {
              t.classList.remove('active'); t.setAttribute('aria-selected', 'false');
            });
            document.querySelectorAll('[id^="' + viewTarget + '-"]').forEach(function (p) { p.classList.remove('active'); });
            this.classList.add('active'); this.setAttribute('aria-selected', 'true');
            var panel = document.getElementById(viewTarget + '-' + day);
            if (panel) panel.classList.add('active');
          });
        });
      })();
    </script>

