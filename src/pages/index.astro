        </div>

        <div class="dark">

        <!-- View tabs -->
        <div class="flex flex-wrap gap-2 mb-6" role="tablist" aria-label="Modo de visualização">
          <button class="view-tab active" data-view="grade" role="tab" aria-selected="true">⊞ Grade</button>
          <button class="view-tab" data-view="sessoes" role="tab" aria-selected="false">☰ Sessões</button>
          <button class="view-tab" data-view="palestrantes" role="tab" aria-selected="false">◉ Palestrantes</button>
        </div>

        <!-- VIEW: GRADE -->
        <div class="view-panel active" id="view-grade">
