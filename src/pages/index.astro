---
import Layout from '~/layouts/PageLayout.astro';
import evento from '~/data/evento.json';
import programacao from '~/data/programacao-gerado.json';
import assinaturas from '~/data/assinaturas.json';
import parceirosData from '~/data/parceiros.json';

const { conf, about, location, hotels, community, partnersGrid } = evento;
const parceiros = parceirosData.organizadores;

const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const asset = (p: string) => base + (p.startsWith('/') ? p : '/' + p);

// ── schedule helpers ────────────────────────────────────────────────────────
const diasMap: Record<string, string> = {
  '18/05 Seg': 'dia1',
  '19/05 Ter': 'dia2',
};

function formatTime(t: string) {
  if (!t) return '';
  const [h, m] = t.split(':');
  const hi = parseInt(h);
  if (isNaN(hi)) return t;
  return m && m !== '00' ? `${hi}h${m}` : `${hi}h`;
}

function isConfirmed(status: string) {
  return (status ?? '').toUpperCase().includes('CONFIRMAD');
}

function parseMin(t: string): number | null {
  if (!t || t.toLowerCase().includes('tarde') || t === '?') return null;
  const [h, m] = t.trim().split(':').map(n => parseInt(n));
  if (isNaN(h)) return null;
  return h * 60 + (isNaN(m) ? 0 : m);
}

function minToTime(m: number): string {
  const h = Math.floor(m / 60), min = m % 60;
  return min === 0 ? `${h}h` : `${h}h${String(min).padStart(2, '0')}`;
}

const BASE_MIN  = 8 * 60;
const SLOT_MIN  = 15;
const SLOT_H_PX = 36;
const locaisOrder = ['Anfiteatro Central', 'Auditório 70 lug.', 'Auditório 50 lug.', 'Auditório 30 lug.'];
const locaisShort = ['Anfiteatro', 'Aud. 70', 'Aud. 50', 'Aud. 30'];

function toRow(min: number): number {
  return Math.max(2, Math.round((min - BASE_MIN) / SLOT_MIN) + 2);
}

const diasConf = [
  { key: 'dia1', diaVal: '18/05 Seg', label: '18 de Maio', color: '#CC2200', endMin: 20 * 60 + 30 },
  { key: 'dia2', diaVal: '19/05 Ter', label: '19 de Maio', color: '#1a5c2a', endMin: 20 * 60 },
];

const sessoes = programacao.sessoes as any[];

const diasData = diasConf.map(dConf => {
  const ss = sessoes.filter((s: any) => s.dia === dConf.diaVal);
  const locaisPresentes = locaisOrder.filter(l => ss.some((s: any) => s.local === l));

  const processed = ss.map((s: any) => {
    const startMin = parseMin(s.inicio);
    if (startMin === null) return { ...s, _startRow: -1, _endRow: -1, _startMin: null };
    let endMin = parseMin(s.fim);
    if (endMin === null) {
      const sameLocalLater = ss
        .filter((x: any) => x.local === s.local && parseMin(x.inicio) !== null && (parseMin(x.inicio) as number) > startMin)
        .map((x: any) => parseMin(x.inicio) as number)
        .sort((a: number, b: number) => a - b);
      endMin = sameLocalLater[0] ?? Math.min(startMin + 60, dConf.endMin);
    }
    return { ...s, _startMin: startMin, _endMin: endMin,
      _startRow: toRow(startMin), _endRow: Math.max(toRow(startMin) + 1, toRow(endMin)) };
  });

  const nSlots = Math.ceil((dConf.endMin - BASE_MIN) / SLOT_MIN);
  const timeAxis: { row: number; label: string; isHour: boolean }[] = [];
  for (let m = BASE_MIN; m <= dConf.endMin; m += 30) {
    timeAxis.push({ row: toRow(m), label: minToTime(m), isHour: m % 60 === 0 });
  }

  const palMap: Record<string, { nome: string; org: string; sessoes: string[] }> = {};
  for (const s of ss) {
    for (const p of (s.palestrantes || [])) {
      if (!isConfirmed(p.status)) continue;
      const key = p.nome.trim();
      if (!palMap[key]) palMap[key] = { nome: p.nome, org: p.organizacao || '', sessoes: [] };
      if (!palMap[key].sessoes.includes(s.titulo)) palMap[key].sessoes.push(s.titulo);
    }
  }
  const palList = Object.values(palMap).sort((a, b) => a.nome.localeCompare(b.nome, 'pt-BR'));

  const sessoesList = [...processed]
    .filter((s: any) => s._startMin !== null)
    .sort((a: any, b: any) => (a._startMin as number) - (b._startMin as number));

  return { ...dConf, locaisPresentes, processed, nSlots, timeAxis, palList, sessoesList };
});

const metadata = {
  title: `${conf.name} — Soberania.Digital`,
  ignoreTitleTemplate: true,
  description: `${conf.date} · ${conf.venue}. ${conf.description}`,
};
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Overpass:wght@300;400;700;900&family=Barlow+Condensed:wght@400;700;900&display=swap');

  .enc { font-family: 'Overpass', Helvetica, Arial, sans-serif; }

  /* ── view tabs (grade/sessões/palestrantes) ── */
  .view-tab {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; font-size: 0.75rem; letter-spacing: 0.5px;
    text-transform: uppercase; padding: 8px 14px; min-height: 44px;
    border: 1px solid #333; background: transparent; color: #555;
    cursor: pointer; transition: all 0.15s;
  }
  @media (min-width: 400px) {
    .view-tab { font-size: 0.85rem; padding: 10px 18px; }
  }
  .view-tab:hover { color: #ccc; border-color: #555; }
  .view-tab.active { background: #FFD400; color: #000; border-color: #FFD400; font-weight: 900; }

  .day-tab {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900; font-size: 0.95rem; text-transform: uppercase;
    letter-spacing: 1px; padding: 10px 20px; min-height: 44px; border: none;
    cursor: pointer; opacity: 0.45; transition: opacity 0.15s; color: white;
    flex: 1 1 0; min-width: 0; text-align: center;
  }
  .day-tab.active { opacity: 1; }
  @media (max-width: 400px) {
    .day-tab { padding: 8px 10px; font-size: 0.78rem; letter-spacing: 0.5px; }
  }

  .view-panel { display: none; }
  .view-panel.active { display: block; }
  .day-panel { display: none; }
  .day-panel.active { display: block; }

  /* ── time grid ── */
  .time-grid-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1px solid #1e1e1e; scroll-behavior: smooth; }
  .time-grid { display: grid; min-width: 480px; }
  .tg-corner { background: #0d0d0d; position: sticky; left: 0; z-index: 20; }
  .tg-room-hdr {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 900;
    font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.5px;
    color: #888; padding: 10px 6px; border-bottom: 1px solid #252525;
    border-left: 1px solid #1a1a1a; background: #111; display: flex; align-items: center;
  }
  @media (min-width: 640px) {
    .tg-room-hdr { font-size: 1rem; padding: 10px 8px; }
  }
  .tg-time {
    font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; color: #444;
    background: #0d0d0d; position: sticky; left: 0; z-index: 10;
    display: flex; align-items: flex-start; padding: 3px 4px 0;
    border-right: 1px solid #1a1a1a;
  }
  @media (min-width: 640px) {
    .tg-time { font-size: 1rem; padding: 3px 6px 0; }
  }
  .tg-time.is-hour { color: #555; border-top: 1px solid #1e1e1e; }
  .tg-time.is-half { border-top: 1px solid #161616; }
  .tg-hour-line { border-top: 1px solid #1a1a1a; pointer-events: none; z-index: 1; }
  .tg-half-line { border-top: 1px solid #131313; pointer-events: none; z-index: 1; }
  .tg-session {
    margin: 2px 3px; padding: 4px 6px;
    border-left: 3px solid var(--dc, #CC2200); background: #141414;
    overflow: hidden; cursor: default; z-index: 5;
    font-size: 0.72rem; line-height: 1.35; position: relative; transition: background 0.1s;
  }
  @media (min-width: 640px) {
    .tg-session { padding: 6px 8px; font-size: 1rem; }
  }
  .tg-session:hover { background: #1c1c1c; }
  .tg-session.intervalo { background: #0a0a0a; border-left-color: #222; }
  .tg-session.especial { background: #111000; border-left-color: #FFD400; }
  .tg-time-badge {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.7rem;
    background: var(--dc, #CC2200); color: white; padding: 1px 4px; border-radius: 2px;
    display: inline-block; margin-bottom: 2px;
  }
  @media (min-width: 640px) {
    .tg-time-badge { font-size: 1rem; padding: 1px 5px; margin-bottom: 3px; }
  }
  .tg-session.intervalo .tg-time-badge { background: #252525; color: #555; }
  .tg-session.especial  .tg-time-badge { background: #FFD400; color: #000; }
  .tg-title {
    display: block; font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; font-size: 0.82rem; color: #ddd; line-height: 1.25; margin-bottom: 2px;
  }
  @media (min-width: 640px) {
    .tg-title { font-size: 1.25rem; margin-bottom: 3px; }
  }
  .tg-session.intervalo .tg-title { color: #444; font-weight: 400; }
  .tg-session.especial  .tg-title { color: #FFD400; }
  .tg-speakers { display: block; font-size: 0.7rem; color: #555; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  @media (min-width: 640px) {
    .tg-speakers { font-size: 1.25rem; }
  }

  /* ── sessions list ── */
  .sl-session { display: flex; gap: 12px; padding: 10px 12px; background: #141414; border-left: 3px solid var(--dc, #CC2200); margin-bottom: 2px; align-items: flex-start; }
  .sl-session.intervalo { border-left-color: #222; background: #0a0a0a; }
  .sl-session.especial  { border-left-color: #FFD400; background: #0f0f00; }
  .sl-time {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 0.78rem;
    background: var(--dc, #CC2200); color: white; padding: 2px 6px; border-radius: 2px;
    flex-shrink: 0; min-width: 38px; text-align: center; white-space: nowrap; margin-top: 1px;
  }
  @media (min-width: 640px) {
    .sl-time { font-size: 1rem; padding: 2px 8px; min-width: 44px; }
  }
  .sl-session.intervalo .sl-time { background: #252525; color: #555; }
  .sl-session.especial  .sl-time { background: #FFD400; color: #000; }
  .sl-body { flex: 1; min-width: 0; }
  .sl-title { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1rem; color: #e0e0e0; line-height: 1.25; margin-bottom: 3px; display: block; }
  @media (min-width: 640px) {
    .sl-title { font-size: 1.25rem; }
  }
  .sl-session.intervalo .sl-title { color: #444; font-weight: 400; }
  .sl-session.especial  .sl-title { color: #FFD400; }
  .sl-local { font-size: 0.78rem; color: #444; font-style: italic; margin-bottom: 4px; display: block; }
  @media (min-width: 640px) {
    .sl-local { font-size: 1rem; }
  }
  .sl-chips { display: flex; flex-wrap: wrap; gap: 4px; }
  .sl-chip { background: #0f2a1a; border: 1px solid #1e4a2a; color: #6fcf97; font-size: 0.72rem; padding: 2px 6px; border-radius: 10px; }
  @media (min-width: 640px) {
    .sl-chip { font-size: 1rem; padding: 2px 8px; }
  }

  /* ── palestrantes ── */
  .pal-item { display: flex; gap: 10px; padding: 10px 12px; border-bottom: 1px solid #161616; align-items: flex-start; }
  .pal-avatar {
    width: 36px; height: 36px; border-radius: 50%; background: #1a1a1a; border: 1px solid #2a2a2a;
    flex-shrink: 0; display: flex; align-items: center; justify-content: center;
    font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1rem; color: #444;
  }
  .pal-nome { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1rem; color: #e0e0e0; display: block; line-height: 1.2; }
  @media (min-width: 640px) {
    .pal-nome { font-size: 1.25rem; }
  }
  .pal-org { font-size: 0.78rem; color: #555; display: block; margin-bottom: 3px; }
  @media (min-width: 640px) {
    .pal-org { font-size: 1rem; }
  }
  .pal-sess { font-size: 0.78rem; color: #FFD400; display: block; line-height: 1.3; }
  @media (min-width: 640px) {
    .pal-sess { font-size: 1rem; }
  }

  /* ── period header ── */
  .period-hdr { display: flex; align-items: center; gap: 8px; padding: 14px 0 6px; }
  .period-hdr span { font-size: 1rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #555; }
  .period-line { flex: 1; height: 1px; background: #1e1e1e; }
</style>

<Layout metadata={metadata}>
  <div class="enc overflow-x-hidden">

<!-- 1. HERO -->
    <section class="bg-[#010101]">

      <!-- mobile hero: imagem de banner full-width -->
      <div class="md:hidden">
        <img
          src={asset('/banner-encontro-1080.png')}
          alt="2º Encontro Nacional pela Soberania Digital — 18 e 19 de Maio, Brasília"
          class="w-full block"
          loading="eager"
        />
        <div class="px-5 py-8 text-center">
          <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-4">
            2º Encontro Nacional pela Soberania Digital
          </p>
          <div class="flex flex-wrap gap-3 justify-center mb-6">
            <div class="text-center">
              <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-0.5">Quando</p>
              <p class="text-white font-bold text-lg">18 e 19 de Maio</p>
            </div>
            <div class="text-center">
              <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-0.5">Onde</p>
              <p class="text-white font-bold text-lg">Brasília / DF</p>
            </div>
          </div>
          <a href="#inscricao"
            class="inline-flex items-center justify-center min-h-[52px] bg-[#E31B23] hover:bg-[#b01015] text-white font-black text-lg uppercase py-3 px-8 border-l-4 border-[#FFD400] transition-colors w-full">
            Inscreva-se
          </a>
        </div>
      </div>

      <!-- desktop hero: banner à esquerda, data + CTA à direita -->
      <div class="hidden md:flex items-center gap-10 max-w-6xl mx-auto px-6 py-12 lg:py-16">
        <div class="flex-1 min-w-0">
          <img
            src={asset('/banner-encontro-1080.png')}
            alt="2º Encontro Nacional pela Soberania Digital"
            class="w-full max-h-[60vh] object-contain block"
            loading="eager"
          />
        </div>
        <div class="flex-shrink-0 w-72 xl:w-80 self-center">
          <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-4">
            2º Encontro Nacional pela Soberania Digital
          </p>
          <h1 class="text-[#FFD400] text-4xl md:text-6xl font-black uppercase leading-none mb-2">18 E 19<br/>DE MAIO</h1>
          <p class="text-[#E7E7D8] text-2xl md:text-4xl font-black uppercase leading-tight mb-8">BRASÍLIA / DF</p>
          <div class="flex flex-col gap-3">
            <a href="#inscricao"
              class="inline-flex items-center justify-center min-h-[52px] bg-[#E31B23] hover:bg-[#b01015] text-white font-black text-lg uppercase py-4 px-8 border-l-4 border-[#FFD400] transition-colors">
              Inscreva-se
            </a>
            <a href="#programacao"
              class="inline-flex items-center justify-center min-h-[48px] border border-[#333] text-[#E7E7D8] hover:border-[#FFD400] hover:text-[#FFD400] font-bold uppercase py-3 px-6 transition-colors text-sm">
              Ver Programação ↓
            </a>
            <a href={asset('/encontro.ics')} download
              class="inline-flex items-center justify-center min-h-[44px] text-[#666] hover:text-[#888] font-bold uppercase py-2 px-4 transition-colors text-xs">
              ↓ Adicionar à agenda (.ics)
            </a>
          </div>
        </div>
      </div>
    </section>

<!-- 2. SOBRE O ENCONTRO -->
    <span class="block h-1 flex-shrink-0 bg-gradient-to-r from-[#E31B23] from-60% to-[#FFD400] to-60%"></span>
    <section class="bg-white dark:bg-[#010101] py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="md:flex items-start gap-12 lg:gap-20">
          <div class="md:basis-2/5 mb-8 md:mb-0 md:sticky md:top-20">
            <p class="text-[#E31B23] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-4">Sobre o Encontro</p>
            <h2 class="text-[#010101] dark:text-white text-3xl md:text-5xl font-black uppercase leading-tight mb-6">Uma luta<br/>do povo</h2>
            <div class="flex flex-wrap gap-3">
              <a href="#inscricao"
                class="inline-flex items-center justify-center min-h-[48px] bg-[#E31B23] hover:bg-[#b01015] text-white font-bold uppercase py-3 px-6 border-l-4 border-[#FFD400] transition-colors text-sm">
                Inscreva-se
              </a>
              <a href="#programacao"
                class="inline-flex items-center justify-center min-h-[48px] border text-[#010101] dark:text-white border-[#e5e7eb] dark:border-[#1f2937] hover:bg-[#E31B23] hover:text-white hover:border-[#E31B23] font-bold uppercase py-3 px-5 transition-colors text-sm">
                Ver Programação
              </a>
            </div>
          </div>
          <div class="md:basis-3/5 min-w-0">
            <p class="text-[#292929] dark:text-[#d1d5db] text-lg leading-relaxed mb-6">{conf.description}</p>
            <p class="text-[#292929] dark:text-[#d1d5db] text-base leading-relaxed mb-8">{about.text}</p>
            <blockquote class="border-l-4 border-[#E31B23] pl-6">
              <p class="text-[#010101] dark:text-white text-2xl md:text-4xl font-black uppercase leading-tight font-semibold italic">"{about.quote}"</p>
            </blockquote>

          </div>
        </div>
      </div>
    </section>

<!-- 3. PROGRAMAÇÃO — 3 VIEWS -->
    <section id="programacao" class="bg-[#0d0d0d] py-10 md:py-14">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">

        <div class="mb-8">
          <p class="text-[#FFD400] text-[0.8125rem] font-bold uppercase tracking-[0.12em] mb-2">Programação Completa</p>
          <h2 class="text-white text-3xl md:text-5xl font-black uppercase leading-tight">O que acontece</h2>
        </div>

        <!-- View tabs -->
        <div class="flex flex-wrap gap-2 mb-6" role="tablist" aria-label="Modo de visualização">
          <button class="view-tab active" data-view="grade" role="tab" aria-selected="true">⊞ Grade</button>
          <button class="view-tab" data-view="sessoes" role="tab" aria-selected="false">☰ Sessões</button>
          <button class="view-tab" data-view="palestrantes" role="tab" aria-selected="false">◉ Palestrantes</button>
        </div>

        <!-- VIEW: GRADE -->
        <div class="view-panel active" id="view-grade">
          <div class="flex mb-0" role="tablist">
            {diasData.map((dia, i) => (
              <button class={`day-tab${i === 0 ? ' active' : ''}`} data-day={dia.key} data-view-target="grade"
                style={`background:${dia.color};border-right:1px solid rgba(0,0,0,.3)`}>
                📅 {dia.label}
              </button>
            ))}
          </div>
          {diasData.map((dia, di) => {
            const nCols = dia.locaisPresentes.length;
            const gridCols = `56px repeat(${nCols}, minmax(160px, 1fr))`;
            const gridRows = `48px repeat(${dia.nSlots}, ${SLOT_H_PX}px)`;
            return (
              <div class={`day-panel${di === 0 ? ' active' : ''}`} id={`grade-${dia.key}`}>
                <div class="time-grid-wrapper">
                  <div class="time-grid" style={`grid-template-columns:${gridCols};grid-template-rows:${gridRows};`}>
                    <div class="tg-corner" style="grid-row:1;grid-column:1;"></div>
                    {dia.locaisPresentes.map((local, li) => (
                      <div class="tg-room-hdr" style={`grid-row:1;grid-column:${li+2};border-top:3px solid ${dia.color};`}>
                        {locaisShort[locaisOrder.indexOf(local)]}
                      </div>
                    ))}
                    {dia.timeAxis.map(t => (
                      <>
                        <div class={`tg-time ${t.isHour ? 'is-hour' : 'is-half'}`} style={`grid-row:${t.row};grid-column:1;align-self:start;`}>
                          {t.isHour ? t.label : ''}
                        </div>
                        <div class={t.isHour ? 'tg-hour-line' : 'tg-half-line'} style={`grid-row:${t.row};grid-column:2 / -1;`}></div>
                      </>
                    ))}
                    {dia.processed.map((s: any) => {
                      if (s._startRow < 2) return null;
                      const colIdx = dia.locaisPresentes.indexOf(s.local) + 2;
                      if (colIdx < 2) return null;
                      const confirmed = (s.palestrantes || []).filter((p: any) => isConfirmed(p.status));
                      const isIntervalo = s.tipo === 'Intervalo';
                      const isEspecial  = s.tipo === 'Especial';
                      return (
                        <div class={`tg-session${isIntervalo ? ' intervalo' : ''}${isEspecial ? ' especial' : ''}`}
                          style={`grid-row:${s._startRow}/${s._endRow};grid-column:${colIdx};--dc:${dia.color};`} title={s.titulo}>
                          <span class="tg-time-badge">{minToTime(s._startMin)}</span>
                          <span class="tg-title">{s.titulo}</span>
                          {confirmed.length > 0 && !isIntervalo && (
                            <span class="tg-speakers">{confirmed.map((p: any) => p.nome).join(' · ')}</span>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
                {nCols > 1 && <p class="text-[#666666] dark:text-[#9ca3af] text-[0.8125rem] leading-relaxed mt-2 text-right">← deslize para ver todos os auditórios →</p>}
              </div>
            );
          })}
        </div>

        <!-- VIEW: SESSÕES -->
        <div class="view-panel" id="view-sessoes">
          <div class="flex mb-4" role="tablist">
            {diasData.map((dia, i) => (
              <button class={`day-tab${i === 0 ? ' active' : ''}`} data-day={dia.key} data-view-target="sessoes"
                style={`background:${dia.color};border-right:1px solid rgba(0,0,0,.3)`}>
                📅 {dia.label}
              </button>
            ))}
          </div>
          {diasData.map((dia, di) => (
            <div class={`day-panel${di === 0 ? ' active' : ''}`} id={`sessoes-${dia.key}`}>
              {[
                { label: 'Manhã', icon: '☀️', test: (m: number | null) => m !== null && m < 13 * 60 },
                { label: 'Tarde', icon: '🌤️', test: (m: number | null) => m !== null && m >= 13 * 60 && m < 18 * 60 },
                { label: 'Noite', icon: '🌙', test: (m: number | null) => m !== null && m >= 18 * 60 },
              ].map(period => {
                const items = dia.sessoesList.filter((s: any) => period.test(s._startMin));
                if (items.length === 0) return null;
                return (
                  <div>
                    <div class="period-hdr">
                      <span style="font-size:1rem">{period.icon}</span>
                      <span>{period.label}</span>
                      <div class="period-line"></div>
                    </div>
                    {items.map((s: any) => {
                      const confirmed = (s.palestrantes || []).filter((p: any) => isConfirmed(p.status));
                      const isIntervalo = s.tipo === 'Intervalo';
                      const isEspecial  = s.tipo === 'Especial';
                      return (
                        <div class={`sl-session${isIntervalo ? ' intervalo' : ''}${isEspecial ? ' especial' : ''}`} style={`--dc:${dia.color};`}>
                          <span class="sl-time">{minToTime(s._startMin as number)}</span>
                          <div class="sl-body">
                            <span class="sl-title">{s.titulo}</span>
                            {dia.locaisPresentes.length > 1 && !isIntervalo && <span class="sl-local">{s.local}</span>}
                            {confirmed.length > 0 && !isIntervalo && (
                              <div class="sl-chips">
                                {confirmed.map((p: any) => (
                                  <span class="sl-chip">{p.nome}{p.organizacao && p.organizacao !== '—' ? ` · ${p.organizacao}` : ''}</span>
                                ))}
                              </div>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                );
              })}
            </div>
          ))}
        </div>

        <!-- VIEW: PALESTRANTES -->
        <div class="view-panel" id="view-palestrantes">
          <div class="flex mb-4" role="tablist">
            {diasData.map((dia, i) => (
              <button class={`day-tab${i === 0 ? ' active' : ''}`} data-day={dia.key} data-view-target="palestrantes"
                style={`background:${dia.color};border-right:1px solid rgba(0,0,0,.3)`}>
                📅 {dia.label}
              </button>
            ))}
          </div>
          {diasData.map((dia, di) => (
            <div class={`day-panel${di === 0 ? ' active' : ''}`} id={`palestrantes-${dia.key}`}>
              {dia.palList.length === 0 ? (
                <p class="text-[#444] text-sm py-8 text-center">Nenhum palestrante confirmado para este dia.</p>
              ) : (
                <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-px bg-[#161616]">
                  {dia.palList.map((pal: any) => (
                    <div class="pal-item bg-[#0d0d0d]">
                      <div class="pal-avatar">{pal.nome.trim()[0]}</div>
                      <div class="flex-1 min-w-0">
                        <span class="pal-nome">{pal.nome}</span>
                        {pal.org && pal.org !== '—' && <span class="pal-org">{pal.org}</span>}
                        {pal.sessoes.map((t: string) => <span class="pal-sess">→ {t}</span>)}
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>

      </div>
    </section>

<!-- 4. BIG NUMBER — INSCRIÇÕES -->
    {assinaturas.total > 0 && (
      <section class="bg-[#111] border-y border-[#FFD400]/20 py-8 md:py-10">
