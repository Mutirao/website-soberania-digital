<script>
fetch('/encontro/api/dados')
  .then(r => r.ok ? r.json() : null)
  .then(dados => {
    if (!dados) return;
    if (dados.inscritos != null) {
      const el = document.getElementById('inscritos-count');
      if (el) el.textContent = dados.inscritos.toLocaleString('pt-BR');
      const timeEl = document.getElementById('inscritos-time');
      if (timeEl) {
        const d = new Date(dados.atualizadoEm);
        timeEl.textContent = 'atualizado em ' + d.toLocaleDateString('pt-BR', {
          day: '2-digit', month: '2-digit', year: 'numeric',
          hour: '2-digit', minute: '2-digit',
        });
      }
    }
    const colaboradores = (dados.parceiros ?? []).filter((p: any) => p.partnerType === 'collaborator');
    if (colaboradores.length) {
      const container = document.getElementById('quem-logos');
      if (container) {
        container.innerHTML = '';
        colaboradores.forEach((p: any) => {
          const a = document.createElement('a');
          a.href = p.link || '#';
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.className = 'inline-flex items-center justify-center bg-white px-4 py-3 opacity-90 hover:opacity-100 transition-opacity';
          const img = document.createElement('img');
          img.src = p.logo;
          img.alt = p.name;
          img.className = 'h-16 w-auto max-w-[160px] object-contain';
          img.loading = 'lazy';
          a.appendChild(img);
          container.appendChild(a);
        });
      }
    }
  })
  .catch(() => {});
</script>
