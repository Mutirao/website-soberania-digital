---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Links Rápidos — Soberania Digital',
  ignoreTitleTemplate: true,
  description: 'Acesse rapidamente os principais links da Rede Nacional pela Soberania Digital.',
};
---

<Layout metadata={metadata}>
  <section class="bg-gray-950 py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="text-center mb-16">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4">Links Rápidos</h1>
        <p class="text-gray-400 text-lg">
          Acesse rapidamente os principais espaços da Rede pela Soberania Digital
        </p>
      </header>

      <div class="space-y-12">
        <div>
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <span class="text-green-400">●</span> Plantaformas
          </h2>
          <div class="grid md:grid-cols-2 gap-4">
            <a href="https://plantaformas.org/conferences/SoberaniaDigital" target="_blank" rel="noopener noreferrer"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Conferência Soberania Digital</h3>
              <p class="text-gray-400 text-sm">Espaço principal de articulação e deliberação da rede</p>
              <span class="text-green-400 text-sm mt-2 inline-block">plantaformas.org →</span>
            </a>
            <a href="https://plantaformas.org/conferences/SoberaniaDigital/f/529/" target="_blank" rel="noopener noreferrer"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Inscrições 2º Encontro</h3>
              <p class="text-gray-400 text-sm">Inscreva-se no 2º Encontro Nacional Soberania Já!</p>
              <span class="text-green-400 text-sm mt-2 inline-block">plantaformas.org →</span>
            </a>
            <a href="https://plantaformas.org/assemblies/soberaniadigital/f/29/meetings" target="_blank" rel="noopener noreferrer"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Reuniões da Rede</h3>
              <p class="text-gray-400 text-sm">Calendário e atas das reuniões regulares</p>
              <span class="text-green-400 text-sm mt-2 inline-block">plantaformas.org →</span>
            </a>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <span class="text-green-400">●</span> Comunicação
          </h2>
          <div class="grid md:grid-cols-2 gap-4">
            <a href="https://t.me/SoberaniaDigitalBR" target="_blank" rel="noopener noreferrer"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Telegram</h3>
              <p class="text-gray-400 text-sm">Grupo principal de comunicação da rede</p>
              <span class="text-green-400 text-sm mt-2 inline-block">t.me/SoberaniaDigitalBR →</span>
            </a>
            <a href="https://matrix.to/#/%23soberaniadigital:matrix.org" target="_blank" rel="noopener noreferrer"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Matrix</h3>
              <p class="text-gray-400 text-sm">Canal na rede federada Matrix — comunicação soberana</p>
              <span class="text-green-400 text-sm mt-2 inline-block">#soberaniadigital:matrix.org →</span>
            </a>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <span class="text-green-400">●</span> Fediverso
          </h2>
          <div class="grid md:grid-cols-2 gap-4">
            <a href="https://organica.social/@soberania" target="_blank" rel="noopener noreferrer"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Mastodon</h3>
              <p class="text-gray-400 text-sm">Siga a rede no Orgânica Social (Mastodon)</p>
              <span class="text-green-400 text-sm mt-2 inline-block">@soberania@organica.social →</span>
            </a>
            <a href="https://videos.organica.social/a/soberania/" target="_blank" rel="noopener noreferrer"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">PeerTube</h3>
              <p class="text-gray-400 text-sm">Vídeos e gravações dos encontros no PeerTube</p>
              <span class="text-green-400 text-sm mt-2 inline-block">videos.organica.social →</span>
            </a>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <span class="text-green-400">●</span> Documentos Colaborativos
          </h2>
          <div class="grid md:grid-cols-2 gap-4">
            <a href="https://pad.riseup.net/p/SoberaniaDigital" target="_blank" rel="noopener noreferrer"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Pad Colaborativo</h3>
              <p class="text-gray-400 text-sm">Documentos de trabalho e construções coletivas</p>
              <span class="text-green-400 text-sm mt-2 inline-block">pad.riseup.net →</span>
            </a>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <span class="text-green-400">●</span> Páginas do Site
          </h2>
          <div class="grid md:grid-cols-2 gap-4">
            <a href="/carta"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Carta ao Presidente Lula</h3>
              <p class="text-gray-400 text-sm">A carta entregue ao Presidente Lula em julho de 2025</p>
              <span class="text-green-400 text-sm mt-2 inline-block">/carta →</span>
            </a>
            <a href="/encontro"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">2º Encontro Nacional</h3>
              <p class="text-gray-400 text-sm">18 e 19 de maio — Brasília/DF</p>
              <span class="text-green-400 text-sm mt-2 inline-block">/encontro →</span>
            </a>
            <a href="/primeiro-encontro"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">1º Encontro Nacional</h3>
              <p class="text-gray-400 text-sm">8 e 9 de julho de 2025 — Brasília/DF</p>
              <span class="text-green-400 text-sm mt-2 inline-block">/primeiro-encontro →</span>
            </a>
            <a href="/manifesto"
              class="block bg-gray-900 hover:bg-gray-800 border border-gray-700 hover:border-green-500/50 rounded-xl p-5 transition-colors">
              <h3 class="text-white font-bold text-lg mb-1">Manifesto</h3>
              <p class="text-gray-400 text-sm">Manifesto pela Soberania Digital nas Universidades</p>
              <span class="text-green-400 text-sm mt-2 inline-block">/manifesto →</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
