---
import Layout from '~/layouts/PageLayout.astro';
import data from '~/data/programacao-gerado.json';
import evento from '~/data/evento.json';

const { conf } = evento;

// ── helpers ────────────────────────────────────────────────────────────────
const sessoes = data.sessoes as any[];

function parseMin(t: string): number | null {
  if (!t || t.toLowerCase().includes('tarde') || t === '?') return null;
  const [h, m] = t.trim().split(':').map(n => parseInt(n));
  if (isNaN(h)) return null;
  return h * 60 + (isNaN(m) ? 0 : m);
}

function minToTime(m: number): string {
  const h = Math.floor(m / 60), min = m % 60;
  return min === 0 ? `${h}h` : `${h}h${String(min).padStart(2, '0')}`;
}

function slugify(s: string) {
  return s.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

function isConfirmed(status: string) {
  return (status ?? '').toUpperCase().includes('CONFIRMAD');
}

// ── config ─────────────────────────────────────────────────────────────────
const BASE_MIN  = 8 * 60;    // grid starts at 8:00
const SLOT_MIN  = 15;        // 15-minute slots
const SLOT_H_PX = 36;        // px per slot

const locaisOrder = [
  'Anfiteatro Central',
  'Auditório 70 lug.',
  'Auditório 50 lug.',
  'Auditório 30 lug.',
];
const locaisShort = ['Anfiteatro', 'Aud. 70', 'Aud. 50', 'Aud. 30'];

const diasConf = [
  { key: 'dia1', diaVal: '18/05 Seg', label: '18 de Maio', color: '#CC2200', endMin: 20 * 60 + 30 },
  { key: 'dia2', diaVal: '19/05 Ter', label: '19 de Maio', color: '#1a5c2a', endMin: 20 * 60 },
];

function toRow(min: number): number {
  return Math.max(2, Math.round((min - BASE_MIN) / SLOT_MIN) + 2);
}

// ── build grid data ────────────────────────────────────────────────────────
const diasData = diasConf.map(dConf => {
  const ss = sessoes.filter(s => s.dia === dConf.diaVal);
  const locaisPresentes = locaisOrder.filter(l => ss.some(s => s.local === l));

  // Fill missing fim times from next session in same local, or default
  const processed = ss.map(s => {
    const startMin = parseMin(s.inicio);
    if (startMin === null) return { ...s, _startRow: -1, _endRow: -1, _startMin: null };

    let endMin = parseMin(s.fim);
    if (endMin === null) {
      const sameLocalLater = ss
        .filter(x => x.local === s.local && parseMin(x.inicio) !== null && (parseMin(x.inicio) as number) > startMin)
        .map(x => parseMin(x.inicio) as number)
        .sort((a, b) => a - b);
      endMin = sameLocalLater[0] ?? Math.min(startMin + 60, dConf.endMin);
    }

    return {
      ...s,
      _startMin: startMin,
      _endMin: endMin,
      _startRow: toRow(startMin),
      _endRow: Math.max(toRow(startMin) + 1, toRow(endMin)),
    };
  });

  // Time axis labels (every 30 min)
  const nSlots = Math.ceil((dConf.endMin - BASE_MIN) / SLOT_MIN);
  const timeAxis: { row: number; label: string; isHour: boolean }[] = [];
  for (let m = BASE_MIN; m <= dConf.endMin; m += 30) {
    timeAxis.push({ row: toRow(m), label: minToTime(m), isHour: m % 60 === 0 });
  }

  // Speakers: extract from sessions (confirmed only)
  const palMap: Record<string, { nome: string; org: string; sessoes: string[] }> = {};
  for (const s of ss) {
    for (const p of (s.palestrantes || [])) {
      if (!isConfirmed(p.status)) continue;
      const key = p.nome.trim();
      if (!palMap[key]) palMap[key] = { nome: p.nome, org: p.organizacao || '', sessoes: [] };
      if (!palMap[key].sessoes.includes(s.titulo)) palMap[key].sessoes.push(s.titulo);
    }
  }
  const palList = Object.values(palMap).sort((a, b) =>
    a.nome.localeCompare(b.nome, 'pt-BR')
  );

  // Sessões list: chronological, skip invalid times
  const sessoesList = [...processed]
    .filter(s => s._startMin !== null)
    .sort((a, b) => (a._startMin as number) - (b._startMin as number));

  return { ...dConf, locaisPresentes, processed, nSlots, timeAxis, palList, sessoesList };
});

const metadata = {
  title: 'Programação — 2º Encontro Nacional pela Soberania Digital',
  ignoreTitleTemplate: true,
  description: 'Veja a programação completa do 2º Encontro Nacional pela Soberania Digital — 18 e 19 de maio de 2026 em Brasília/DF.',
};
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,700&display=swap');

  .prog-page {
    background: #0d0d0d;
    color: #e8e8e8;
    --red:    #CC2200;
    --green:  #1a5c2a;
    --yellow: #FFD400;
  }
  .barlow { font-family: 'Barlow Condensed', sans-serif; }

  /* ── view tabs ────────────────────────────────────────────────── */
  .view-tab {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 8px 20px;
    border: 1px solid #333;
    background: transparent;
    color: #555;
    cursor: pointer;
    transition: all 0.15s;
  }
  .view-tab:hover { color: #ccc; border-color: #555; }
  .view-tab.active { background: #FFD400; color: #000; border-color: #FFD400; font-weight: 900; }

  /* ── day tabs ─────────────────────────────────────────────────── */
  .day-tab {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 8px 20px;
    border: none;
    cursor: pointer;
    opacity: 0.45;
    transition: opacity 0.15s;
    color: white;
  }
  .day-tab.active { opacity: 1; }

  /* ── view panels ──────────────────────────────────────────────── */
  .view-panel { display: none; }
  .view-panel.active { display: block; }

  /* ── day panels ───────────────────────────────────────────────── */
  .day-panel { display: none; }
  .day-panel.active { display: block; }

  /* ═══════════════════════════════════════════════════════════════
     TIME GRID
  ═══════════════════════════════════════════════════════════════ */
  .time-grid-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid #1e1e1e;
  }

  .time-grid {
    display: grid;
    min-width: 480px;
  }

  /* Room headers (row 1) */
  .tg-corner {
    background: #0d0d0d;
    position: sticky;
    left: 0;
    z-index: 20;
  }
  .tg-room-hdr {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #888;
    padding: 10px 8px;
    border-bottom: 1px solid #252525;
    border-left: 1px solid #1a1a1a;
    background: #111;
    display: flex;
    align-items: center;
  }

  /* Time labels (column 1) */
  .tg-time {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.65rem;
    color: #444;
    padding: 0 6px;
    background: #0d0d0d;
    position: sticky;
    left: 0;
    z-index: 10;
    display: flex;
    align-items: flex-start;
    padding-top: 3px;
    border-right: 1px solid #1a1a1a;
  }
  .tg-time.is-hour { color: #555; border-top: 1px solid #1e1e1e; }
  .tg-time.is-half { border-top: 1px solid #161616; }

  /* Hour lines (span all cols) */
  .tg-hour-line {
    border-top: 1px solid #1a1a1a;
    pointer-events: none;
    z-index: 1;
  }
  .tg-half-line {
    border-top: 1px solid #131313;
    pointer-events: none;
    z-index: 1;
  }

  /* Session cards */
  .tg-session {
    margin: 2px 3px;
    padding: 5px 7px;
    border-left: 3px solid var(--dc, #CC2200);
    background: #141414;
    overflow: hidden;
    cursor: default;
    z-index: 5;
    font-size: 0.72rem;
    line-height: 1.3;
    position: relative;
    transition: background 0.1s;
  }
  .tg-session:hover { background: #1c1c1c; }
  .tg-session.intervalo {
    background: #0a0a0a;
    border-left-color: #222;
  }
  .tg-session.especial {
    background: #111000;
    border-left-color: #FFD400;
  }

  .tg-time-badge {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.68rem;
    background: var(--dc, #CC2200);
    color: white;
    padding: 1px 5px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 3px;
  }
  .tg-session.intervalo .tg-time-badge { background: #252525; color: #555; }
  .tg-session.especial  .tg-time-badge { background: #FFD400; color: #000; }

  .tg-title {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    color: #ddd;
    line-height: 1.25;
    margin-bottom: 3px;
  }
  .tg-session.intervalo .tg-title { color: #444; font-weight: 400; }
  .tg-session.especial  .tg-title { color: #FFD400; }

  .tg-speakers {
    display: block;
    font-size: 0.65rem;
    color: #555;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ═══════════════════════════════════════════════════════════════
     SESSIONS LIST VIEW
  ═══════════════════════════════════════════════════════════════ */
  .sl-session {
    display: flex;
    gap: 12px;
    padding: 10px 12px;
    background: #141414;
    border-left: 3px solid var(--dc, #CC2200);
    margin-bottom: 2px;
    align-items: flex-start;
  }
  .sl-session.intervalo { border-left-color: #222; background: #0a0a0a; }
  .sl-session.especial  { border-left-color: #FFD400; background: #0f0f00; }

  .sl-time {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    background: var(--dc, #CC2200);
    color: white;
    padding: 2px 8px;
    border-radius: 2px;
    flex-shrink: 0;
    min-width: 44px;
    text-align: center;
    white-space: nowrap;
    margin-top: 1px;
  }
  .sl-session.intervalo .sl-time { background: #252525; color: #555; }
  .sl-session.especial  .sl-time { background: #FFD400; color: #000; }

  .sl-body { flex: 1; min-width: 0; }
  .sl-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #e0e0e0;
    line-height: 1.3;
    margin-bottom: 3px;
    display: block;
  }
  .sl-session.intervalo .sl-title { color: #444; font-weight: 400; }
  .sl-session.especial  .sl-title { color: #FFD400; }

  .sl-local {
    font-size: 0.68rem;
    color: #444;
    font-style: italic;
    margin-bottom: 4px;
    display: block;
  }

  .sl-chips { display: flex; flex-wrap: wrap; gap: 4px; }
  .sl-chip {
    background: #0f2a1a;
    border: 1px solid #1e4a2a;
    color: #6fcf97;
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 10px;
  }

  /* ═══════════════════════════════════════════════════════════════
     SPEAKERS VIEW
  ═══════════════════════════════════════════════════════════════ */
  .pal-item {
    display: flex;
    gap: 10px;
    padding: 10px 12px;
    border-bottom: 1px solid #161616;
    align-items: flex-start;
  }
  .pal-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1rem;
    color: #444;
  }
  .pal-nome {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #e0e0e0;
    display: block;
    line-height: 1.2;
  }
  .pal-org {
    font-size: 0.72rem;
    color: #555;
    display: block;
    margin-bottom: 3px;
  }
  .pal-sess {
    font-size: 0.7rem;
    color: #FFD400;
    display: block;
    line-height: 1.3;
  }

  /* ── hero typography ──────────────────────────────────────────── */
  .hero-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    line-height: 0.9;
    text-transform: uppercase;
  }
  .hero-tagline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .motivo-icon { width: 64px; height: 64px; object-fit: contain; }

  /* ── period header ────────────────────────────────────────────── */
  .period-hdr {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 0 6px;
  }
  .period-hdr span { font-size: 0.7rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #555; }
  .period-line { flex: 1; height: 1px; background: #1e1e1e; }
</style>

<Layout metadata={metadata}>
  <div class="prog-page overflow-x-hidden">

    <!-- ═══════════════════════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════════════════════ -->
    <section class="relative bg-[#0d0d0d] border-b border-[#222]">
      <div class="h-[3px] w-full" style="background:linear-gradient(90deg,#CC2200 0%,#CC2200 40%,#FFD400 40%,#FFD400 70%,#1a5c2a 70%,#1a5c2a 100%)"></div>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14 md:py-20">
        <p class="barlow text-[#FFD400] font-black uppercase tracking-widest text-sm mb-4">
          2º Encontro Nacional pela Soberania Digital
        </p>
        <h1 class="hero-title text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-white mb-2">
          SOBERANI<span class="text-[#CC2200]">A</span><br/>DIGITAL JÁ!
        </h1>
        <p class="hero-tagline text-[#666] text-xs sm:text-sm mb-8">Sem ela, não há soberania nacional</p>
        <div class="flex flex-wrap gap-6 md:gap-12 mb-8">
          {[
            { label: 'Quando', value: '18 e 19 de Maio' },
            { label: 'Onde',   value: 'Brasília / DF' },
            { label: 'Local',  value: 'Sindicato dos Bancários' },
          ].map(m => (
            <div>
              <p class="barlow text-[#FFD400] font-black uppercase tracking-widest text-xs mb-0.5">{m.label}</p>
              <p class="barlow text-white font-bold text-lg">{m.value}</p>
            </div>
          ))}
        </div>
        <div class="flex flex-wrap gap-3">
          <a href={conf.callToAction.link} target="_blank" rel="noopener noreferrer"
            class="barlow inline-flex items-center min-h-[48px] bg-[#CC2200] hover:bg-[#aa1a00] text-white font-black text-lg uppercase tracking-wide py-2 px-8 border-l-4 border-[#FFD400] transition-colors">
            Inscreva-se
          </a>
          <a href="/encontro.ics" download
            class="barlow inline-flex items-center min-h-[48px] border border-[#444] text-[#aaa] hover:border-[#FFD400] hover:text-[#FFD400] font-bold text-base uppercase py-2 px-6 transition-colors">
            ↓ .ics
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         MOTIVOS
    ═══════════════════════════════════════════════════════════════ -->
    <section class="bg-[#111] border-b border-[#222] py-10">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <p class="barlow text-center text-[#444] uppercase tracking-widest text-xs mb-8">
          Quem controla a tecnologia controla o país
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            { icon: '/icons/programa/economia.png',    title: 'Economia',           text: 'Dependência de plataformas e infraestruturas estrangeiras que controlam os fluxos do país.' },
            { icon: '/icons/programa/democracia.png',  title: 'Democracia',         text: 'Algoritmos moldam o debate público, a informação e o processo eleitoral.' },
            { icon: '/icons/programa/organizacao.png', title: 'Organização Social', text: 'Movimentos dependem de ferramentas que podem ser desligadas a qualquer momento.' },
          ].map(m => (
            <div class="flex flex-col items-center text-center p-6 border border-[#222] bg-[#141414]">
              <img src={m.icon} alt={m.title} class="motivo-icon mb-4" />
              <h3 class="barlow text-[#FFD400] font-black uppercase tracking-wider text-base mb-2">{m.title}</h3>
              <p class="text-[#888] text-sm leading-relaxed">{m.text}</p>
            </div>
          ))}
        </div>
        <p class="barlow text-center text-[#CC2200] font-black uppercase tracking-widest text-sm mt-8">
          Não é tecnologia. É poder.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         PROGRAMAÇÃO — 3 VIEWS
    ═══════════════════════════════════════════════════════════════ -->
    <section class="py-10 md:py-14">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">

        <!-- Section title -->
        <div class="mb-8">
          <p class="barlow text-[#FFD400] font-black uppercase tracking-widest text-xs mb-2">Programação Completa</p>
          <h2 class="barlow text-3xl md:text-4xl font-black text-white uppercase">O que acontece</h2>
        </div>

        <!-- View tabs -->
        <div class="flex flex-wrap gap-2 mb-6" role="tablist" aria-label="Modo de visualização">
          <button class="view-tab active" data-view="grade" role="tab" aria-selected="true">
            ⊞ Grade
          </button>
          <button class="view-tab" data-view="sessoes" role="tab" aria-selected="false">
            ☰ Sessões
          </button>
          <button class="view-tab" data-view="palestrantes" role="tab" aria-selected="false">
            ◉ Palestrantes
          </button>
        </div>

        <!-- ── VIEW: GRADE ── -->
        <div class="view-panel active" id="view-grade">

          <!-- Day tabs -->
          <div class="flex mb-0" role="tablist" aria-label="Dia">
            {diasData.map((dia, i) => (
              <button
                class={`day-tab${i === 0 ? ' active' : ''}`}
                data-day={dia.key}
                data-view-target="grade"
                role="tab"
                style={`background: ${dia.color}; border-right: 1px solid rgba(0,0,0,0.3)`}
              >
                📅 {dia.label}
              </button>
            ))}
          </div>

          {diasData.map((dia, di) => {
            const nCols = dia.locaisPresentes.length;
            const gridCols = `56px repeat(${nCols}, minmax(160px, 1fr))`;
            const gridRows = `48px repeat(${dia.nSlots}, ${SLOT_H_PX}px)`;

            return (
              <div
                class={`day-panel${di === 0 ? ' active' : ''}`}
                id={`grade-${dia.key}`}
              >
                <div class="time-grid-wrapper">
                  <div
                    class="time-grid"
                    style={`grid-template-columns: ${gridCols}; grid-template-rows: ${gridRows};`}
                  >
                    {/* Corner */}
                    <div class="tg-corner" style="grid-row: 1; grid-column: 1;"></div>

                    {/* Room headers */}
                    {dia.locaisPresentes.map((local, li) => (
                      <div
                        class="tg-room-hdr"
                        style={`grid-row: 1; grid-column: ${li + 2}; border-top: 3px solid ${dia.color};`}
                      >
                        {locaisShort[locaisOrder.indexOf(local)]}
                      </div>
                    ))}

                    {/* Time labels + grid lines */}
                    {dia.timeAxis.map(t => (
                      <>
                        <div
                          class={`tg-time ${t.isHour ? 'is-hour' : 'is-half'}`}
                          style={`grid-row: ${t.row}; grid-column: 1; align-self: start;`}
                        >
                          {t.isHour ? t.label : ''}
                        </div>
                        <div
                          class={t.isHour ? 'tg-hour-line' : 'tg-half-line'}
                          style={`grid-row: ${t.row}; grid-column: 2 / -1;`}
                        ></div>
                      </>
                    ))}

                    {/* Sessions */}
                    {dia.processed.map(s => {
                      if (s._startRow < 2) return null;
                      const colIdx = dia.locaisPresentes.indexOf(s.local) + 2;
                      if (colIdx < 2) return null;
                      const confirmed = (s.palestrantes || []).filter((p: any) => isConfirmed(p.status));
                      const isIntervalo = s.tipo === 'Intervalo';
                      const isEspecial  = s.tipo === 'Especial';

                      return (
                        <div
                          class={`tg-session ${isIntervalo ? 'intervalo' : ''} ${isEspecial ? 'especial' : ''}`}
                          style={`grid-row: ${s._startRow} / ${s._endRow}; grid-column: ${colIdx}; --dc: ${dia.color};`}
                          title={s.titulo}
                        >
                          <span class="tg-time-badge">{minToTime(s._startMin)}</span>
                          <span class="tg-title">{s.titulo}</span>
                          {confirmed.length > 0 && !isIntervalo && (
                            <span class="tg-speakers">
                              {confirmed.map((p: any) => p.nome).join(' · ')}
                            </span>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
                {nCols > 1 && (
                  <p class="text-[#333] text-xs mt-2 text-right">← deslize para ver todos os auditórios →</p>
                )}
              </div>
            );
          })}
        </div>

        <!-- ── VIEW: SESSÕES ── -->
        <div class="view-panel" id="view-sessoes">

          <div class="flex mb-4" role="tablist" aria-label="Dia">
            {diasData.map((dia, i) => (
              <button
                class={`day-tab${i === 0 ? ' active' : ''}`}
                data-day={dia.key}
                data-view-target="sessoes"
                role="tab"
                style={`background: ${dia.color}; border-right: 1px solid rgba(0,0,0,0.3)`}
              >
                📅 {dia.label}
              </button>
            ))}
          </div>

          {diasData.map((dia, di) => (
            <div class={`day-panel${di === 0 ? ' active' : ''}`} id={`sessoes-${dia.key}`}>

              {/* Group by period */}
              {[
                { key: 'manha', label: 'Manhã',  icon: '☀️', test: (m: number | null) => m !== null && m < 13 * 60 },
                { key: 'tarde', label: 'Tarde',  icon: '🌤️', test: (m: number | null) => m !== null && m >= 13 * 60 && m < 18 * 60 },
                { key: 'noite', label: 'Noite',  icon: '🌙', test: (m: number | null) => m !== null && m >= 18 * 60 },
              ].map(period => {
                const items = dia.sessoesList.filter(s => period.test(s._startMin));
                if (items.length === 0) return null;
                return (
                  <div>
                    <div class="period-hdr">
                      <span style="font-size:1rem">{period.icon}</span>
                      <span>{period.label}</span>
                      <div class="period-line" />
                    </div>
                    {items.map(s => {
                      const confirmed = (s.palestrantes || []).filter((p: any) => isConfirmed(p.status));
                      const isIntervalo = s.tipo === 'Intervalo';
                      const isEspecial  = s.tipo === 'Especial';
                      const multiLocal  = dia.locaisPresentes.length > 1;
                      return (
                        <div
                          class={`sl-session ${isIntervalo ? 'intervalo' : ''} ${isEspecial ? 'especial' : ''}`}
                          style={`--dc: ${dia.color};`}
                        >
                          <span class="sl-time">{minToTime(s._startMin as number)}</span>
                          <div class="sl-body">
                            <span class="sl-title">{s.titulo}</span>
                            {multiLocal && !isIntervalo && (
                              <span class="sl-local">{s.local}</span>
                            )}
                            {confirmed.length > 0 && !isIntervalo && (
                              <div class="sl-chips">
                                {confirmed.map((p: any) => (
                                  <span class="sl-chip">
                                    {p.nome}{p.organizacao && p.organizacao !== '—' ? ` · ${p.organizacao}` : ''}
                                  </span>
                                ))}
                              </div>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                );
              })}
            </div>
          ))}
        </div>

        <!-- ── VIEW: PALESTRANTES ── -->
        <div class="view-panel" id="view-palestrantes">

          <div class="flex mb-4" role="tablist" aria-label="Dia">
            {diasData.map((dia, i) => (
              <button
                class={`day-tab${i === 0 ? ' active' : ''}`}
                data-day={dia.key}
                data-view-target="palestrantes"
                role="tab"
                style={`background: ${dia.color}; border-right: 1px solid rgba(0,0,0,0.3)`}
              >
                📅 {dia.label}
              </button>
            ))}
          </div>

          {diasData.map((dia, di) => (
            <div class={`day-panel${di === 0 ? ' active' : ''}`} id={`palestrantes-${dia.key}`}>
              {dia.palList.length === 0 ? (
                <p class="text-[#444] text-sm py-8 text-center">Nenhum palestrante confirmado para este dia.</p>
              ) : (
                <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-px bg-[#161616]">
                  {dia.palList.map(pal => (
                    <div class="pal-item bg-[#0d0d0d]">
                      <div class="pal-avatar">{pal.nome.trim()[0]}</div>
                      <div class="flex-1 min-w-0">
                        <span class="pal-nome">{pal.nome}</span>
                        {pal.org && pal.org !== '—' && (
                          <span class="pal-org">{pal.org}</span>
                        )}
                        {pal.sessoes.map(t => (
                          <span class="pal-sess">→ {t}</span>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         CTA
    ═══════════════════════════════════════════════════════════════ -->
    <section class="bg-[#CC2200] py-14 md:py-18">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="barlow text-3xl md:text-4xl font-black text-white uppercase mb-3">
          Chegou a hora de decidir
        </h2>
        <p class="barlow text-red-200 text-lg uppercase tracking-wide mb-8">
          Quem controla o futuro do Brasil
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href={conf.callToAction.link} target="_blank" rel="noopener noreferrer"
            class="barlow inline-flex items-center min-h-[52px] bg-[#0d0d0d] hover:bg-[#222] text-white font-black text-xl uppercase py-3 px-10 border-l-4 border-[#FFD400] transition-colors">
            Inscreva-se
          </a>
          <a href="/encontro"
            class="barlow inline-flex items-center min-h-[52px] border-2 border-white text-white hover:bg-white hover:text-[#CC2200] font-black text-xl uppercase py-3 px-8 transition-colors">
            Mais informações
          </a>
        </div>
        <p class="text-red-300 text-sm mt-6">soberania.digital</p>
      </div>
    </section>

  </div>
</Layout>

<script is:inline>
  (function () {
    // ── View tabs ──────────────────────────────────────────────────────────
    document.querySelectorAll('.view-tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        var view = this.getAttribute('data-view');
        document.querySelectorAll('.view-tab').forEach(function (t) {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        document.querySelectorAll('.view-panel').forEach(function (p) {
          p.classList.remove('active');
        });
        this.classList.add('active');
        this.setAttribute('aria-selected', 'true');
        var panel = document.getElementById('view-' + view);
        if (panel) panel.classList.add('active');
      });
    });

    // ── Day tabs (per view) ────────────────────────────────────────────────
    document.querySelectorAll('.day-tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        var day = this.getAttribute('data-day');
        var viewTarget = this.getAttribute('data-view-target');

        // Reset tabs in this group
        this.closest('.view-panel').querySelectorAll('.day-tab').forEach(function (t) {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });

        // Hide all day panels in this view
        ['grade', 'sessoes', 'palestrantes'].forEach(function (v) {
          var panel = document.getElementById(v + '-' + day);
          // Only reset panels in the current view target
        });

        // Hide panels for this view target
        document.querySelectorAll('[id^="' + viewTarget + '-"]').forEach(function (p) {
          p.classList.remove('active');
        });

        this.classList.add('active');
        this.setAttribute('aria-selected', 'true');
        var panel = document.getElementById(viewTarget + '-' + day);
        if (panel) panel.classList.add('active');
      });
    });
  })();
</script>
