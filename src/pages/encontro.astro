---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '2º Encontro Nacional pela Soberania Digital — Soberania Já!',
  ignoreTitleTemplate: true,
  description: '18 e 19 de Maio em Brasília/DF. Territórios e Movimentos pelo Futuro do Brasil.',
};
---

<Layout metadata={metadata}>
  <section class="relative bg-gray-950">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-20">
      <div class="md:flex items-center gap-10">
        <div class="md:basis-1/2 mb-8 md:mb-0">
          <img
            src="/banner-encontro-1080.png"
            alt="2º Encontro Nacional pela Soberania Digital — 18 e 19 de Maio, Brasília"
            class="w-full rounded-lg shadow-2xl"
          />
        </div>
        <div class="md:basis-1/2 text-center md:text-left">
          <div class="inline-block bg-green-500 text-white font-black text-sm uppercase tracking-widest px-4 py-2 rounded mb-6">
            18 e 19 de Maio · Brasília / DF
          </div>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-tight mb-4">
            2º Encontro Nacional<br />pela Soberania Digital
          </h1>
          <p class="text-3xl md:text-4xl font-black text-green-400 mb-4">SOBERANIA JÁ!</p>
          <p class="text-lg text-gray-300 mb-8 max-w-lg">
            Territórios e Movimentos pelo Futuro do Brasil
          </p>
          <div class="flex flex-wrap gap-4 justify-center md:justify-start">
            <a href="https://plantaformas.org/conferences/SoberaniaDigital/f/529/" target="_blank" rel="noopener noreferrer"
              class="inline-block bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-8 rounded-lg text-lg transition-colors shadow-lg">
              Inscreva-se
            </a>
            <a href="#programacao"
              class="inline-block border-2 border-green-500 text-green-400 hover:bg-green-500 hover:text-white font-bold py-3 px-8 rounded-lg text-lg transition-colors">
              Programação
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="programacao" class="bg-gray-950 py-16 md:py-24 border-t border-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <img src="/banner-encontro-1080-v2.png" alt="Programação 2º Encontro" class="mx-auto max-w-md mb-8 rounded-lg" />
        <h2 class="text-3xl md:text-4xl font-bold text-white">Programação</h2>
      </div>

      <div class="md:flex gap-8 items-start">
        <div class="md:basis-1/2 mb-8 md:mb-0">
          <h3 class="text-2xl font-bold text-green-400 text-center mb-6">Dia 01 — 18 de maio</h3>
          <img src="/programacao-dia1.png" alt="Programação Dia 1 — 18 de maio" class="w-full rounded-lg shadow-lg" />
        </div>
        <div class="md:basis-1/2">
          <h3 class="text-2xl font-bold text-green-400 text-center mb-6">Dia 02 — 19 de maio</h3>
          <img src="/programacao-dia2.png" alt="Programação Dia 2 — 19 de maio" class="w-full rounded-lg shadow-lg" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-900 py-16 md:py-24 border-t border-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="md:flex items-center gap-10">
        <div class="md:basis-1/2 mb-8 md:mb-0">
          <img
            src="/encontro-foto-grupo.jpeg"
            alt="Foto do grupo no 1º Encontro Nacional Soberania Já!"
            class="w-full rounded-lg shadow-xl"
            loading="lazy"
          />
        </div>
        <div class="md:basis-1/2">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
            Reunião aberta
          </h2>
          <h3 class="text-2xl font-bold text-green-400 mb-6">
            Soberania Digital e Popular
          </h3>
          <p class="text-lg text-gray-300 leading-relaxed mb-6">
            A Rede pela Soberania Digital e a Campanha Internet Legal se juntaram para uma reunião aberta com José Dirceu sobre Soberania Digital e Popular, caminhos e propostas.
          </p>
          <p class="text-lg text-gray-300 leading-relaxed">
            Após o sucesso do primeiro encontro nacional, movimentos sociais, coletivos digitais, sindicatos, universidades e organizações de todo o Brasil se reúnem novamente em Brasília para debater e construir propostas concretas pela soberania digital do país.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-950 py-16 md:py-20 border-t border-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <img
        src="/identidade-visual-soberania.png"
        alt="Rede pela Soberania Digital"
        class="mx-auto max-w-2xl mb-10 rounded-lg"
        loading="lazy"
      />
      <blockquote class="text-xl md:text-2xl text-gray-300 italic leading-relaxed max-w-4xl mx-auto mb-8">
        Precisamos de um projeto estruturante, nacional e coletivo, que aponte caminhos concretos para a construção de uma infraestrutura digital própria, baseada em código aberto, tecnologias públicas e controle democrático sobre dados, algoritmos e redes, com foco na Soberania Digital e Popular.
      </blockquote>
      <p class="text-gray-400 text-sm mb-2">
        A reunião inaugural da Rede foi realizada no dia <strong class="text-white">1 de julho de 2023</strong>.
      </p>
      <p class="text-gray-300">
        Junte-se a nós nesse processo colaborativo e vital para o futuro da nossa sociedade.
      </p>
    </div>
  </section>

  <section class="bg-gray-900 py-16 border-t border-gray-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-10">
        Leia, Assine e faça parte dessa <span class="text-green-400">Luta!</span>
      </h2>
      <div class="space-y-5">
        <a
          href="https://t.me/SoberaniaDigitalBR"
          target="_blank"
          class="flex items-center gap-4 p-5 bg-blue-600 hover:bg-blue-700 rounded-xl transition-colors"
        >
          <svg class="w-10 h-10 text-white flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          <div>
            <div class="text-white font-bold text-lg">Entre para nosso grupo no Telegram</div>
            <div class="text-blue-200 text-sm">t.me/SoberaniaDigitalBR</div>
          </div>
        </a>

        <a
          href="https://matrix.to/#/%23soberaniadigital:matrix.org"
          target="_blank"
          class="flex items-center gap-4 p-5 bg-gray-800 hover:bg-gray-700 rounded-xl transition-colors"
        >
          <svg class="w-10 h-10 text-green-400 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M.632.55v22.9H2.28V24H0V0h2.28v.55zm7.043 7.26v1.157h.033c.309-.443.683-.784 1.117-1.024.433-.245.936-.365 1.5-.365.54 0 1.033.107 1.481.314.448.208.785.582 1.011 1.119.251-.373.591-.7.901-.981.42-.281.93-.422 1.533-.422.445 0 .855.055 1.232.166.376.111.697.29.963.537.267.247.472.572.617.976.145.403.217.893.217 1.47v5.991h-2.316v-5.08c0-.375-.023-.7-.07-.971a1.774 1.774 0 0 0-.254-.706 1.12 1.12 0 0 0-.511-.437c-.217-.1-.496-.15-.838-.15-.339 0-.62.058-.842.173a1.224 1.224 0 0 0-.511.463 1.862 1.862 0 0 0-.254.706c-.047.271-.07.596-.07.971v5.08h-2.316v-5.08c0-.37-.012-.697-.037-.974a1.812 1.812 0 0 0-.224-.737 1.1 1.1 0 0 0-.502-.484c-.217-.11-.505-.166-.863-.166a1.79 1.79 0 0 0-.478.074 1.513 1.513 0 0 0-.608.333c-.217.192-.397.472-.539.842-.142.37-.213.86-.213 1.47v5.08H7.675V7.81zm15.693 15.64V.55H21.72V0H24v24h-2.28v-.55z"/>
          </svg>
          <div>
            <div class="text-white font-bold text-lg">Entre para nosso grupo da Rede Matrix</div>
            <div class="text-gray-400 text-sm">#soberaniadigital:matrix.org</div>
          </div>
        </a>

        <a
          href="/carta"
          class="flex items-center gap-4 p-5 bg-green-600 hover:bg-green-700 rounded-xl transition-colors"
        >
          <svg class="w-10 h-10 text-white flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <div>
            <div class="text-white font-bold text-lg">LEIA E ASSINE NOSSA CARTA. COMPARTILHE!</div>
            <div class="text-green-200 text-sm">Acessar documento completo</div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-gray-950 py-16 border-t border-gray-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-10">Onde se hospedar em Brasília</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
          <h3 class="text-white font-bold text-lg mb-3">LIKE U HOTEIS</h3>
          <p class="text-green-400 font-semibold text-sm mb-2">Desconto SESC 30%</p>
          <p class="text-gray-300 text-sm mb-3">SHS Quadra 04, Bloco F, Asa Sul</p>
          <p class="text-gray-400 text-sm">Tel: (61) 3121-6300</p>
        </div>
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
          <h3 class="text-white font-bold text-lg mb-3">Joy Hostels</h3>
          <p class="text-gray-300 text-sm mb-3">SCRN 702/703, Bloco H, Asa Norte</p>
          <p class="text-gray-400 text-sm">Tel: (61) 3542-9909</p>
        </div>
        <div class="bg-gray-900 rounded-xl p-6 border border-gray-800">
          <h3 class="text-white font-bold text-lg mb-3">Freeway Hostels</h3>
          <p class="text-gray-300 text-sm mb-3">SHCGN 708 bloco I, Asa Norte</p>
          <p class="text-gray-400 text-sm">Tel: (61) 99616-7091</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-green-600">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-green-100 font-bold uppercase tracking-widest mb-2 text-sm">PRESTA ATENÇÃO NAS REUNIÕES DA</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">
        Rede PELA SOBERANIA DIGITAL
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="https://plantaformas.org/assemblies/soberaniadigital/f/29/meetings"
          target="_blank"
          class="inline-block bg-white text-green-700 hover:bg-gray-100 font-bold py-3 px-8 rounded-lg text-lg transition-colors shadow-lg"
        >
          VEJA NAS PLATAFORMAS
        </a>
        <a
          href="https://t.me/SoberaniaDigitalBR"
          target="_blank"
          class="inline-block bg-gray-900 text-white hover:bg-gray-800 font-bold py-3 px-8 rounded-lg text-lg transition-colors shadow-lg"
        >
          Telegram
        </a>
      </div>
    </div>
  </section>
</Layout>
