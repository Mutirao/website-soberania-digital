---
import Layout from '~/layouts/PageLayout.astro';
import evento from '~/data/evento.json';

const { conf, about, location, schedule, hotels, community } = evento;
const { stories = [] } = evento;

const showStories = stories.length >= 3;

const metadata = {
  title: `${conf.name} — Soberania.Digital`,
  ignoreTitleTemplate: true,
  description: `${conf.date} · ${conf.venue}. ${conf.description}`,
};
---

<style>
  .encontro-page {
    --enc-accent: #FFD400;
    --enc-cta: #E31B23;
    --enc-cta-hover: #b01015;
    --enc-border-accent: #FFD400;
  }
</style>

<Layout metadata={metadata}>
  <div class="overflow-x-hidden encontro-page">

    <!-- 1. MANIFESTO HERO -->
    <section class="relative bg-[#010101]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 md:py-24 lg:py-32">
        <div class="max-w-3xl">
          <p class="text-[#FFD400] font-black uppercase tracking-widest text-sm mb-6">
            2º Encontro Nacional pela Soberania Digital
          </p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white uppercase leading-none mb-8">
            A soberania digital<br />é uma luta do povo
          </h1>
          <p class="text-lg md:text-xl text-[#E7E7D8] font-light leading-relaxed mb-10 max-w-xl">
            {/* MANIFESTO COPY */}
            O Brasil precisa ter mais controle sobre suas infraestruturas, seus dados,
            suas plataformas e seus caminhos tecnológicos.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={conf.callToAction.link} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center justify-center min-h-[52px] bg-[#E31B23] hover:bg-[#b01015] text-white font-bold py-3 px-8 text-lg transition-colors shadow-lg border-l-4 border-[#FFD400]">
              Inscreva-se
            </a>
            <a href="#programacao"
              class="inline-flex items-center justify-center min-h-[52px] border-2 border-[#FFD400] text-[#FFD400] hover:bg-[#FFD400] hover:text-[#010101] font-bold py-3 px-6 text-base transition-colors">
              Ver Programação
            </a>
          </div>
        </div>
        <div class="mt-12 md:mt-16 flex flex-wrap gap-6 md:gap-12">
          <div>
            <p class="text-[#FFD400] font-black uppercase tracking-widest text-xs mb-1">Quando</p>
            <p class="text-white font-bold text-lg">18 e 19 de MAIO</p>
          </div>
          <div>
            <p class="text-[#FFD400] font-black uppercase tracking-widest text-xs mb-1">Onde</p>
            <p class="text-white font-bold text-lg">Brasília / DF</p>
          </div>
          <div>
            <p class="text-[#FFD400] font-black uppercase tracking-widest text-xs mb-1">Inscrições</p>
            <p class="text-white font-bold text-lg">Abertas</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. COMMUNITY STORIES -->
    {showStories && (
      <section class="bg-[var(--sd-section-alt-bg)] py-16 md:py-24 border-t border-[var(--sd-card-border)]">
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
          <div class="text-center mb-12">
            <p class="text-[#E31B23] font-black uppercase tracking-widest text-sm mb-3">
              Quem esteve lá
            </p>
            <h2 class="text-3xl md:text-4xl font-black text-[var(--sd-text)] uppercase">
              O que disseram
            </h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {stories.map((story) => (
              <div class="p-6 bg-[var(--sd-card-bg)] border border-[var(--sd-card-border)] border-l-4 border-l-[#FFD400]">
                <p class="text-lg font-semibold text-[var(--sd-text)] leading-snug mb-4">
                  "{story.quote}"
                </p>
                <p class="text-[#E31B23] font-bold text-sm">
                  {story.name}
                </p>
                <p class="text-[var(--sd-text-muted)] text-sm">
                  {story.city}{story.role ? ` · ${story.role}` : ''}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- 3. WHY THIS MATTERS -->
    <section class="bg-[var(--sd-section-bg)] py-16 md:py-24 border-t border-[var(--sd-card-border)]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="md:flex items-start gap-12">
          <div class="md:basis-1/3 mb-8 md:mb-0">
            <p class="text-[#E31B23] font-black uppercase tracking-widest text-sm mb-3">
              Por que importa
            </p>
            <h2 class="text-3xl md:text-4xl font-black text-[var(--sd-text)] uppercase leading-tight">
              Uma luta que já começou
            </h2>
          </div>
          <div class="md:basis-2/3 min-w-0">
            <p class="text-base text-[var(--sd-text-2)] leading-relaxed mb-6">
              O encontro é parte de um processo de articulação para fazer com que a soberania digital entre de vez na pauta do país, esteja presente nos debates eleitorais, nos planos de governo e nas estratégias para o desenvolvimento nacional.
            </p>
            <p class="text-base text-[var(--sd-text-2)] leading-relaxed mb-6">
              Esse movimento quer se fortalecer de forma enraizada e espraiada em todos os territórios, conectando lutas, experiências e propostas que nascem das comunidades, das universidades, dos movimentos sociais, do poder público e da sociedade civil organizada.
            </p>
            <blockquote class="text-xl md:text-2xl text-[var(--sd-text)] font-semibold italic leading-snug border-l-4 border-[#E31B23] pl-6">
              {about.quote}
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. SCHEDULE -->
    <section id="programacao" class="bg-[#010101] py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="text-[#FFD400] font-black uppercase tracking-widest text-sm mb-3">
            Programação
          </p>
          <h2 class="text-3xl md:text-4xl font-black text-white uppercase">
            O que acontece
          </h2>
        </div>

        <div class="space-y-12 lg:space-y-0 lg:flex lg:gap-8 lg:items-start">
          {schedule.map((day) => (
            <div class="lg:basis-1/2">
              <h3 class="text-xl md:text-2xl font-bold text-[#FFD400] text-center mb-1">
                {day.label} — {day.date}
              </h3>
              {day.room && (
                <p class="text-center text-[#E7E7D8] text-sm mb-4">{day.room}</p>
              )}
              <div class="rounded overflow-hidden border border-[#292929]">
                {day.slots.map((slot) => (
                  <div class={`flex gap-3 md:gap-4 p-3 md:p-4 min-w-0 border-b border-[#292929] last:border-b-0 ${!slot.presentation ? 'bg-[#1a1a1a]' : 'bg-[#010101]'}`}>
                    <div class="text-[#FFD400] font-mono text-sm whitespace-nowrap pt-0.5 w-14 shrink-0">
                      {slot.time}
                    </div>
                    <div class="flex-1 min-w-0">
                      {slot.presentation ? (
                        <>
                          <p class="text-white font-bold text-sm leading-snug mb-1">
                            {slot.presentation.title}
                          </p>
                          {slot.presentation.description && (
                            <p class="text-[#E7E7D8] text-xs leading-snug mb-2">
                              {slot.presentation.description}
                            </p>
                          )}
                          {slot.speakers && slot.speakers.length > 0 && (
                            <div class="flex flex-wrap gap-x-3 gap-y-0.5">
                              {slot.speakers.map((s) => (
                                <span class="text-[#FFD400] text-xs md:text-sm font-semibold">
                                  {s.role === 'mediação' && <span class="text-[#666] font-normal italic">med: </span>}
                                  {s.name}{s.company ? ` · ${s.company}` : ''}
                                </span>
                              ))}
                            </div>
                          )}
                        </>
                      ) : (
                        <p class="text-white font-bold text-sm">
                          {slot.name}
                        </p>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. REGISTRATION CTA -->
    <section class="bg-[#E31B23] py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-black text-white uppercase mb-4">
          Garante sua vaga
        </h2>
        <p class="text-base md:text-lg text-pink-100 mb-8 max-w-xl mx-auto">
          {conf.date} em {conf.venue}. Participe da construção de um futuro digital soberano para o Brasil.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href={conf.callToAction.link} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center min-h-[52px] bg-[#010101] hover:bg-[#292929] text-white font-bold py-3 px-12 text-xl transition-colors shadow-lg border-l-4 border-[#FFD400]">
            {conf.callToAction.text}
          </a>
          <a href="/encontro.ics" download
            class="inline-flex items-center justify-center gap-2 min-h-[52px] border-2 border-white text-white hover:bg-white hover:text-[#E31B23] font-bold py-3 px-8 text-xl transition-colors">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Baixar Programação (.ics)
          </a>
        </div>
      </div>
    </section>

    <!-- 6. LOCATION + HOTELS -->
    <section id="local" class="bg-[var(--sd-section-bg)] py-16 md:py-24 border-t border-[var(--sd-card-border)]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10">
          <p class="text-[#E31B23] font-black uppercase tracking-widest text-sm mb-3">
            Local do evento
          </p>
          <h2 class="text-3xl md:text-4xl font-black text-[var(--sd-text)] mb-2">
            {location.name}
          </h2>
          <p class="text-[var(--sd-text-2)] mb-6">{location.address}</p>
        </div>

        <!-- Mapa OpenStreetMap com Leaflet -->
        <div class="mb-10">
          <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
          <div id="osm-map" class="w-full rounded overflow-hidden border border-[var(--sd-card-border)] shadow-lg" style="height: 420px;"></div>
          <div class="flex flex-wrap gap-3 mt-4 justify-center text-sm">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-[var(--sd-card-bg)] border border-[var(--sd-card-border)]">
              <span class="w-3 h-3 rounded-full bg-[#E31B23] inline-block"></span> Local do Encontro
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-[var(--sd-card-bg)] border border-[var(--sd-card-border)]">
              <span class="w-3 h-3 rounded-full bg-[#45a2ca] inline-block"></span> Hotéis
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-[var(--sd-card-bg)] border border-[var(--sd-card-border)]">
              <span class="w-3 h-3 rounded-full bg-[#77b978] inline-block"></span> Aeroporto
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-[var(--sd-card-bg)] border border-[var(--sd-card-border)]">
              <span class="w-3 h-3 rounded-full bg-[#FFD400] inline-block"></span> Rodoviária
            </span>
          </div>
        </div>

        <!-- Hotéis -->
        <div class="border-t border-[var(--sd-card-border)] pt-10 mt-10">
          <h3 class="text-xl md:text-2xl font-black text-[var(--sd-text)] text-center mb-8">
            Onde se hospedar em Brasília
          </h3>
          <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {hotels.map((hotel) => (
              <div class="bg-[var(--sd-card-bg)] p-5 border border-[var(--sd-card-border)]">
                <h4 class="text-[var(--sd-text)] font-bold text-base mb-1">{hotel.name}</h4>
                {hotel.note && (
                  <p class="text-[#E31B23] font-semibold text-sm mb-2">{hotel.note}</p>
                )}
                <p class="text-[var(--sd-text-2)] text-sm mb-2">{hotel.address}</p>
                {hotel.email && (
                  <p class="text-[var(--sd-text-muted)] text-sm mb-1">{hotel.email}</p>
                )}
                {hotel.phone && (
                  <p class="text-[var(--sd-text-muted)] text-sm mb-2">Tel: {hotel.phone}</p>
                )}
                {hotel.url && (
                  <a href={hotel.url} target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center justify-center min-h-[48px] mt-1 text-[#E31B23] font-semibold text-sm hover:underline">
                    Site →
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- Aeroporto e Rodoviária -->
        <div class="border-t border-[var(--sd-card-border)] pt-10 mt-10">
          <h3 class="text-xl md:text-2xl font-black text-[var(--sd-text)] text-center mb-8">
            Como Chegar
          </h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-[var(--sd-card-bg)] p-6 border border-[var(--sd-card-border)]">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-2xl">✈️</span>
                <h4 class="text-[var(--sd-text)] font-bold text-lg">Aeroporto de Brasília (BSB)</h4>
              </div>
              <p class="text-[var(--sd-text-2)] text-sm mb-2">Aeroporto Internacional Juscelino Kubitschek</p>
              <p class="text-[var(--sd-text-muted)] text-sm mb-2">Lago Sul, Brasília — DF</p>
              <p class="text-[var(--sd-text-2)] text-sm mb-1"><strong>Distância:</strong> ~15 km do local do evento (20-30 min de carro)</p>
              <p class="text-[var(--sd-text-muted)] text-xs">Táxi/Uber disponível 24h. Ônibus executivo para Rodoviária do Plano Piloto.</p>
            </div>
            <div class="bg-[var(--sd-card-bg)] p-6 border border-[var(--sd-card-border)]">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-2xl">🚌</span>
                <h4 class="text-[var(--sd-text)] font-bold text-lg">Rodoviária do Plano Piloto</h4>
              </div>
              <p class="text-[var(--sd-text-2)] text-sm mb-2">Rodoviária Interestadual de Brasília</p>
              <p class="text-[var(--sd-text-muted)] text-sm mb-2">SMAS, Trecho 4, Conjunto 5/6 — Asa Sul</p>
              <p class="text-[var(--sd-text-2)] text-sm mb-1"><strong>Distância:</strong> ~7 km do local do evento (15 min de carro)</p>
              <p class="text-[var(--sd-text-muted)] text-xs">Metrô (Estação Shopping) + caminhada. Táxi/Uber disponível.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Leaflet Map Script -->
    <script is:inline>
      (function() {
        var mapEl = document.getElementById('osm-map');
        if (!mapEl) return;

        if (!document.querySelector('link[href*="leaflet"]')) {
          var css = document.createElement('link');
          css.rel = 'stylesheet';
          css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
          document.head.appendChild(css);
        }

        function initMap() {
          if (typeof L === 'undefined') {
            var script = document.createElement('script');
            script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
            script.onload = buildMap;
            document.head.appendChild(script);
          } else {
            buildMap();
          }
        }

        function buildMap() {
          var map = L.map('osm-map').setView([-15.790, -47.888], 13);

          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 19,
          }).addTo(map);

          var venueIcon = L.divIcon({
            className: 'custom-marker',
            html: '<div style="background:#E31B23;color:white;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;border:3px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3)">📍</div>',
            iconSize: [30, 30],
            iconAnchor: [15, 15],
          });
          L.marker([-15.7993, -47.8905], { icon: venueIcon })
            .addTo(map)
            .bindPopup('<strong>Sindicato e Teatro dos Bancários</strong><br>EQS 314/315, Asa Sul<br>📍 Local do 2º Encontro');

          var hotelIcon = L.divIcon({
            className: 'custom-marker',
            html: '<div style="background:#45a2ca;color:white;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;border:2px solid white;box-shadow:0 1px 4px rgba(0,0,0,0.3)">🏨</div>',
            iconSize: [22, 22],
            iconAnchor: [11, 11],
          });

          var hotels = [
            { name: 'LIKE U HOTEIS', lat: -15.7895, lng: -47.8850, desc: 'SHS Quadra 04, Bloco F — 30% desc SESC' },
            { name: 'Joy Hostels', lat: -15.7779, lng: -47.8920, desc: 'SCRN 702/703, Bloco H, Asa Norte' },
            { name: 'Freeway Hostels', lat: -15.7670, lng: -47.8880, desc: 'SHCGN 708 bloco I, Asa Norte' },
          ];

          hotels.forEach(function(h) {
            L.marker([h.lat, h.lng], { icon: hotelIcon })
              .addTo(map)
              .bindPopup('<strong>' + h.name + '</strong><br>' + h.desc);
          });

          var airportIcon = L.divIcon({
            className: 'custom-marker',
            html: '<div style="background:#77b978;color:white;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;border:2px solid white;box-shadow:0 1px 4px rgba(0,0,0,0.3)">✈️</div>',
            iconSize: [26, 26],
            iconAnchor: [13, 13],
          });
          L.marker([-15.8697, -47.9177], { icon: airportIcon })
            .addTo(map)
            .bindPopup('<strong>✈️ Aeroporto de Brasília (BSB)</strong><br>~15 km do local | 20-30 min');

          var busIcon = L.divIcon({
            className: 'custom-marker',
            html: '<div style="background:#FFD400;color:#010101;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;border:2px solid white;box-shadow:0 1px 4px rgba(0,0,0,0.3)">🚌</div>',
            iconSize: [26, 26],
            iconAnchor: [13, 13],
          });
          L.marker([-15.7934, -47.8826], { icon: busIcon })
            .addTo(map)
            .bindPopup('<strong>🚌 Rodoviária do Plano Piloto</strong><br>~7 km do local | 15 min');
        }

        initMap();
      })();
    </script>

    <!-- 7. COMMUNITY -->
    <section class="bg-[#010101] py-16 border-t border-[#292929]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10">
          <p class="text-[#FFD400] font-black uppercase tracking-widest text-sm mb-3">
            Faça parte
          </p>
          <h2 class="text-3xl md:text-4xl font-black text-white uppercase">
            Participe da <span class="text-[#E31B23]">Rede</span>
          </h2>
        </div>
        <div class="space-y-3">
          {community.map((item) => (
            <a
              href={item.url}
              target={item.url.startsWith('/') ? undefined : '_blank'}
              rel={item.url.startsWith('/') ? undefined : 'noopener noreferrer'}
              class="flex items-center gap-4 p-4 transition-colors min-h-[48px]"
              style={`background-color: ${item.color}`}
            >
              {item.icon === 'telegram' && (
                <svg class="w-8 h-8 text-white flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
                </svg>
              )}
              {item.icon === 'matrix' && (
                <svg class="w-8 h-8 text-[#E31B23] flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M.632.55v22.9H2.28V24H0V0h2.28v.55zm7.043 7.26v1.157h.033c.309-.443.683-.784 1.117-1.024.433-.245.936-.365 1.5-.365.54 0 1.033.107 1.481.314.448.208.785.582 1.011 1.119.251-.373.591-.7.901-.981.42-.281.93-.422 1.533-.422.445 0 .855.055 1.232.166.376.111.697.29.963.537.267.247.472.572.617.976.145.403.217.893.217 1.47v5.991h-2.316v-5.08c0-.375-.023-.7-.07-.971a1.774 1.774 0 0 0-.254-.706 1.12 1.12 0 0 0-.511-.437c-.217-.1-.496-.15-.838-.15-.339 0-.62.058-.842.173a1.224 1.224 0 0 0-.511.463 1.862 1.862 0 0 0-.254.706c-.047.271-.07.596-.07.971v5.08h-2.316v-5.08c0-.37-.012-.697-.037-.974a1.812 1.812 0 0 0-.224-.737 1.1 1.1 0 0 0-.502-.484c-.217-.11-.505-.166-.863-.166a1.79 1.79 0 0 0-.478.074 1.513 1.513 0 0 0-.608.333c-.217.192-.397.472-.539.842-.142.37-.213.86-.213 1.47v5.08H7.675V7.81zm15.693 15.64V.55H21.72V0H24v24h-2.28v-.55z"/>
                </svg>
