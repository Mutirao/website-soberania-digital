---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(34 197 94);
    --aw-color-secondary: rgb(22 163 74);
    --aw-color-accent: rgb(34 197 94);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 7 18);

    ::selection {
      background-color: rgb(34 197 94 / 40%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(34 197 94);
    --aw-color-secondary: rgb(22 163 74);
    --aw-color-accent: rgb(34 197 94);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 7 18);

    ::selection {
      background-color: rgb(34 197 94 / 40%);
      color: white;
    }
  }

  html {
    scroll-behavior: smooth;
  }
</style>
