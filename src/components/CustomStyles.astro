---
import '@fontsource-variable/inter';
---

<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=Overpass:wght@400;500;700;900&display=swap');

  :root {
    --aw-font-sans: 'Overpass', 'Inter Variable', sans-serif;
    --aw-font-serif: 'Overpass', 'Inter Variable', sans-serif;
    --aw-font-heading: 'Overpass', 'Inter Variable', sans-serif;

    --aw-color-primary: #45a2ca;
    --aw-color-secondary: #59c3c3;
    --aw-color-accent: #77b978;

    --aw-color-text-heading: #010101;
    --aw-color-text-default: #333333;
    --aw-color-text-muted: #333333 / 66%;
    --aw-color-bg-page: #ffffff;

    --sd-section-bg: #ffffff;
    --sd-section-alt-bg: #f7f7f7;
    --sd-text: #010101;
    --sd-text-2: #555555;
    --sd-text-muted: #888888;
    --sd-card-bg: #ffffff;
    --sd-card-border: #e5e7eb;
    --sd-primary: #004a8e;
    --sd-primary-hover: #003d73;

    ::selection {
      background-color: #45a2ca / 40%;
    }
  }

  .dark {
    --aw-color-text-heading: #ffffff;
    --aw-color-text-default: #e0e0e0;
    --aw-color-text-muted: #e0e0e0 / 66%;
    --aw-color-bg-page: #010101;

    --sd-section-bg: #010101;
    --sd-section-alt-bg: #010101;
    --sd-text: #ffffff;
    --sd-text-2: #d1d5db;
    --sd-text-muted: #9ca3af;
    --sd-card-bg: #111111;
    --sd-card-border: #1e1e1e;
    --sd-primary: #45a2ca;
    --sd-primary-hover: #3a8ab0;

    ::selection {
      background-color: #45a2ca / 40%;
      color: white;
    }
  }

  html {
    scroll-behavior: smooth;
    font-family: 'Overpass', 'Inter Variable', sans-serif;
  }

  h1, h2, h3, h4, h5, h6 {
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    text-wrap: balance;
  }

  :root {
    --enc-text: #010101;
    --enc-text-body: #292929;
    --enc-text-muted: #666666;
    --enc-c4: #aaaaaa;
    --enc-surface: #ffffff;
    --enc-surface-alt: #f7f7f7;
    --enc-card-bg: #ffffff;
    --enc-card-border: #e5e7eb;
  }

  .dark {
    --enc-text: #ffffff;
    --enc-text-body: #d1d5db;
    --enc-text-muted: #9ca3af;
    --enc-c4: #666666;
    --enc-surface: #010101;
    --enc-surface-alt: #010101;
    --enc-card-bg: #111111;
    --enc-card-border: #1e1e1e;
  }

  .enc-stripe {
    display: block;
    height: 4px;
    flex-shrink: 0;
    background: linear-gradient(to right, #E31B23 60%, #FFD400 60%);
  }

  @keyframes fadeInUp {
    0% { opacity: 0; transform: translateY(2rem); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .enc-fade {
    animation: fadeInUp 1s both;
  }
</style>
