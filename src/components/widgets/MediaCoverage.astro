---
---

<section class="relative py-20 bg-[var(--sd-section-bg)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <div class="inline-block bg-[var(--sd-card-bg)] px-4 py-1 mb-4">
        <span class="text-[var(--sd-text-muted)] text-sm font-medium">NA MÍDIA</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-bold text-[var(--sd-text)] mb-4">
        SOBERANIA DIGITAL <span class="text-[#45a2ca]">NA MÍDIA!</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <a
        href="https://neofeed.com.br/experts/e-preciso-falar-sobre-soberania-digital/"
        target="_blank"
        class="group bg-[var(--sd-card-bg)] hover:bg-[var(--sd-card-bg)] border border-[var(--sd-card-border)] hover:border-[#45a2ca] transition-all overflow-hidden"
      >
        <div class="relative aspect-video overflow-hidden">
          <img src="/thumb-neofeed.png" alt="Artigo NeoFEED" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--sd-card-bg)] via-transparent to-transparent"></div>
        </div>
        <div class="p-6">
          <div class="mb-4 h-10 flex items-center">
            <img src="/logo_Neofeed_laranja.webp" alt="NeoFEED" class="max-h-10 w-auto" />
          </div>
          <h3 class="text-[var(--sd-text)] font-bold text-lg mb-2">
            "É PRECISO FALAR SOBRE SOBERANIA DIGITAL"
          </h3>
          <div class="mt-4 text-[#45a2ca] group-hover:text-[#59c3c3] transition-colors text-sm font-medium">
            Ler artigo →
          </div>
        </div>
      </a>

      <a
        href="https://epocanegocios.globo.com/colunas/iagora/coluna/2023/10/democracia-e-soberania-digital.ghtml"
        target="_blank"
        class="group bg-[var(--sd-card-bg)] hover:bg-[var(--sd-card-bg)] border border-[var(--sd-card-border)] hover:border-[#45a2ca] transition-all overflow-hidden"
      >
        <div class="relative aspect-video overflow-hidden">
          <img src="/thumb-epoca-negocios.png" alt="Artigo Época Negócios" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--sd-card-bg)] via-transparent to-transparent"></div>
        </div>
        <div class="p-6">
          <div class="mb-4 h-10 flex items-center">
            <img src="/Design-sem-nome-58.png" alt="Época Negócios" class="max-h-10 w-auto" />
          </div>
          <h3 class="text-[var(--sd-text)] font-bold text-lg mb-2">
            "DEMOCRACIA E SOBERANIA DIGITAL"
          </h3>
          <div class="mt-4 text-[#45a2ca] group-hover:text-[#59c3c3] transition-colors text-sm font-medium">
            Ler artigo →
          </div>
        </div>
      </a>

      <a
        href="https://outraspalavras.net/tecnologiaemdisputa/nao-havera-soberania-digital-sem-o-estado/"
        target="_blank"
        class="group bg-[var(--sd-card-bg)] hover:bg-[var(--sd-card-bg)] border border-[var(--sd-card-border)] hover:border-[#45a2ca] transition-all overflow-hidden"
      >
        <div class="relative aspect-video overflow-hidden">
          <img src="/thumb-outras-palavras.png" alt="Artigo Outras Palavras" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--sd-card-bg)] via-transparent to-transparent"></div>
        </div>
        <div class="p-6">
          <div class="mb-4 h-10 flex items-center">
            <img src="/outras-palavras.png" alt="Outras Palavras" class="max-h-10 w-auto" />
          </div>
          <h3 class="text-[var(--sd-text)] font-bold text-lg mb-2">
            "Não haverá soberania digital sem o Estado"
          </h3>
          <div class="mt-4 text-[#45a2ca] group-hover:text-[#59c3c3] transition-colors text-sm font-medium">
            Ler artigo →
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
