---
---

<section class="relative flex items-center justify-center overflow-hidden bg-[var(--sd-section-bg)]" style="min-height: 430px; aspect-ratio: 16/9;">

  <div class="absolute inset-0 overflow-hidden">
    <img
      src="/di-cavalcanti-topo.jpg"
      alt="Arte de Di Cavalcanti"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-[var(--sd-section-bg)]"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 text-center py-12 sm:py-16">
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 sm:mb-8 leading-tight drop-shadow-lg" style="text-transform: uppercase;">
      Rede pela <span class="text-[#c60548]">Soberania Digital</span>
    </h1>

    <p class="text-base sm:text-lg md:text-xl text-gray-200 max-w-3xl mx-auto mb-8 sm:mb-10 leading-relaxed drop-shadow">
      Uma articulação liderada pela <strong class="text-white">Sociedade Civil</strong>, com participação de Movimentos, Comunidades, Universidades, Sindicatos, Parlamentares e outras Lideranças Sociais, nas <strong class="text-white">5 regiões</strong> do país.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
      <a
        href="/encontro"
        class="inline-block bg-[#c60548] hover:bg-[#a0043c] text-white font-bold py-3 px-6 sm:py-4 sm:px-8 text-base sm:text-lg transition-colors shadow-lg"
      >
        Inscreva-se no 2º Encontro
      </a>
      <a
        href="/carta"
        class="inline-block bg-transparent border-2 border-white hover:bg-white hover:text-[#010101] text-white font-bold py-3 px-6 sm:py-4 sm:px-8 text-base sm:px-8 text-base sm:text-lg transition-colors"
      >
        Leia a Carta
      </a>
    </div>
  </div>
</section>
