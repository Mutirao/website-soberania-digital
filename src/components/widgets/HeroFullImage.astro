---
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/di-cavalcanti-topo.jpg"
      alt="Arte de Di Cavalcanti"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-gray-950"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 text-center py-20">
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-8 leading-tight drop-shadow-lg">
      Rede pela <span class="text-green-400">Soberania Digital</span>
    </h1>

    <p class="text-lg sm:text-xl md:text-2xl text-gray-200 max-w-3xl mx-auto mb-10 leading-relaxed drop-shadow">
      Uma articulação liderada pela <strong class="text-white">Sociedade Civil</strong>, com participação de Movimentos, Comunidades, Universidades, Sindicatos, Parlamentares e outras Lideranças Sociais, nas <strong class="text-white">5 regiões</strong> do país.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://soberania.digital/encontro/"
        target="_blank"
        class="inline-block bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-8 rounded-lg text-lg transition-colors shadow-lg"
      >
        Inscreva-se no 2º Encontro
      </a>
      <a
        href="https://soberania.digital/carta/"
        target="_blank"
        class="inline-block bg-transparent border-2 border-white hover:bg-white hover:text-gray-900 text-white font-bold py-4 px-8 rounded-lg text-lg transition-colors"
      >
        Leia a Carta
      </a>
    </div>
  </div>
</section>
