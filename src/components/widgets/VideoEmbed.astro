---
interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = 'Vídeo' } = Astro.props;
const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
---

<section class="relative py-12 md:py-20 bg-[var(--sd-section-bg)]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8 md:mb-12">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[var(--sd-text)] mb-4">
        <span class="text-[#45a2ca]">A Emergência</span> da Soberania Digital
      </h2>
      <p class="text-base md:text-xl text-[var(--sd-text-2)]">
        ENTENDA MAIS SOBRE O ASSUNTO VENDO A AULA DO PROFESSOR SÉRGIO AMADEU
      </p>
    </div>

    <div
      id="yt-facade"
      class="relative aspect-video overflow-hidden shadow-2xl max-w-4xl mx-auto cursor-pointer group"
      data-video-id={videoId}
    >
      <img
        src={thumbnailUrl}
        alt={title}
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-black/30 group-hover:bg-black/20 transition-colors flex items-center justify-center">
        <div class="w-14 h-14 md:w-20 md:h-20 rounded-full bg-[#c60548] flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 md:w-8 md:h-8 text-white ml-1" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </div>
      </div>
    </div>

    <p class="text-center text-[var(--sd-text-muted)] mt-4 md:mt-6 max-w-3xl mx-auto text-sm md:text-base">
      A soberania digital aparece como elemento indispensável para a autodeterminação individual e coletiva do futuro da humanidade.
    </p>
  </div>
</section>

<style is:inline>
  #yt-facade .yt-played {
    display: none;
  }
</style>

<script is:inline>
  document.getElementById('yt-facade')?.addEventListener('click', function() {
    const id = this.getAttribute('data-video-id');
    if (!id) return;
    this.innerHTML = '<iframe width="100%" height="100%" src="https://www.youtube.com/embed/' + id + '?autoplay=1&rel=0" title="Vídeo" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="w-full h-full"></iframe>';
    this.classList.remove('cursor-pointer');
    this.style.cursor = 'default';
  });
</script>
