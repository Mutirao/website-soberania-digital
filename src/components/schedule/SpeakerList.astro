---
import type { DiaData } from '~/types/schedule';

export interface Props {
  dia: DiaData;
}
const { dia } = Astro.props;
---

{dia.palList.length === 0 ? (
  <p class="text-[#444] text-sm py-8 text-center">Nenhum palestrante confirmado para este dia.</p>
) : (
  <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-px bg-[#161616]">
    {dia.palList.map((pal) => (
      <div class="pal-item bg-[#0d0d0d]">
        <div class="pal-avatar">{pal.nome.trim()[0]}</div>
        <div class="flex-1 min-w-0">
          <span class="pal-nome">{pal.nome}</span>
          {pal.org && pal.org !== '—' && <span class="pal-org">{pal.org}</span>}
          {pal.sessoes.map((t: string) => <span class="pal-sess">→ {t}</span>)}
        </div>
      </div>
    ))}
  </div>
)}

<style>
  .pal-item { display: flex; gap: 10px; padding: 10px 12px; border-bottom: 1px solid #161616; align-items: flex-start; }
  .pal-avatar {
    width: 36px; height: 36px; border-radius: 50%; background: #1a1a1a; border: 1px solid #2a2a2a;
    flex-shrink: 0; display: flex; align-items: center; justify-content: center;
    font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 1rem; color: #444;
  }
  .pal-nome { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1rem; color: #e0e0e0; display: block; line-height: 1.2; }
  @media (min-width: 640px) {
    .pal-nome { font-size: 1.25rem; }
  }
  .pal-org { font-size: 0.78rem; color: #555; display: block; margin-bottom: 3px; }
  @media (min-width: 640px) {
    .pal-org { font-size: 1rem; }
  }
  .pal-sess { font-size: 0.78rem; color: #FFD400; display: block; line-height: 1.3; }
  @media (min-width: 640px) {
    .pal-sess { font-size: 1rem; }
  }
</style>
