---
const views = [
  { id: 'grade', label: 'Grade', icon: '⊞' },
  { id: 'sessoes', label: 'Sessões', icon: '☰' },
  { id: 'palestrantes', label: 'Palestrantes', icon: '◉' },
];
---

<div class="flex flex-wrap gap-2 mb-6" role="tablist" aria-label="Modo de visualização">
  {
    views.map((v, i) => (
      <button
        class={`view-tab${i === 0 ? ' active' : ''}`}
        data-view={v.id}
        role="tab"
        id={`view-tab-${v.id}`}
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`view-${v.id}`}
        tabindex={i === 0 ? 0 : -1}
      >
        <span aria-hidden="true">{v.icon}</span> {v.label}
      </button>
    ))
  }
</div>

<style>
  .view-tab {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 8px 14px;
    min-height: 44px;
    border: 1px solid #333;
    background: transparent;
    color: #555;
    cursor: pointer;
    transition: all 0.15s;
  }
  @media (min-width: 400px) {
    .view-tab {
      font-size: 0.85rem;
      padding: 10px 18px;
    }
  }
  .view-tab:hover {
    color: #ccc;
    border-color: #555;
  }
  .view-tab:focus-visible {
    outline: 2px solid #e31b23;
    outline-offset: 2px;
  }
  .view-tab.active {
    background: #ffd400;
    color: #000;
    border-color: #ffd400;
    font-weight: 900;
  }
</style>
