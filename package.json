{
  "name": "website-soberania-digital",
  "version": "1.0.0-beta.52",
  "description": "Website Soberania Digital - Astro 6 and Tailwind CSS 4.",
  "type": "module",
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >= 21.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build:data": "npx tsx scripts/fetch-assinaturas.ts && npx tsx scripts/fetch-parceiros.ts",
    "build": "npm run build:data && astro build",
    "build:ci": "npx tsx scripts/fetch-parceiros.ts && astro build",
    "start": "HOST=0.0.0.0 node ./dist/server/entry.mjs",
    "preview": "npm run build:ci && node ./dist/server/entry.mjs",
    "fetch-assinaturas": "npx tsx scripts/fetch-assinaturas.ts",
    "fetch-parceiros": "npx tsx scripts/fetch-parceiros.ts",
    "astro": "astro",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.0",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.4.2",
    "@astrolib/analytics": "^0.6.1",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource-variable/inter": "^5.2.6",
    "@tailwindcss/vite": "^4.1.8",
    "astro": "^6.3.0",
    "astro-embed": "^0.9.0",
    "astro-icon": "^1.1.5",
    "limax": "4.1.0",
    "lodash.merge": "^4.6.2",
    "tailwindcss": "^4.1.8",
    "unpic": "^4.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/partytown": "^2.1.4",
    "@eslint/js": "^9.33.0",
    "@iconify-json/flat-color-icons": "^1.2.1",
    "@iconify-json/tabler": "^1.2.20",
    "@tailwindcss/typography": "^0.5.16",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "astro-compress": "2.3.8",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.3.0",
    "js-yaml": "^4.1.0",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "0.34.3",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "unist-util-visit": "^5.0.0"
  }
}
